@page
@model SWP_QA_TOOL.Pages.Account.AccessDeniedModel
@{
    ViewData["Title"] = "Truy cập bị từ chối";
    Layout = "_Layout";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-danger">
                <div class="card-header bg-danger text-white">
                    <h4 class="mb-0"><i class="bi bi-shield-exclamation"></i> Truy cập bị từ chối</h4>
                </div>
                <div class="card-body text-center">
                    <div class="mb-4">
                        <i class="bi bi-x-octagon text-danger" style="font-size: 5rem;"></i>
                    </div>
                    <h5>Bạn không có quyền truy cập trang này</h5>
                    <p class="text-muted">
                        Tài khoản của bạn không có đủ quyền để xem nội dung này.
                        Vui lòng liên hệ quản trị viên nếu bạn cho rằng đây là lỗi.
                    </p>
                    <hr />
                    <div class="d-flex justify-content-center gap-3">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            var role = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value;
                            <a href="@(role switch { "Admin" => "/Admin", "Instructor" => "/Instructor", "Student" => "/Student", _ => "/" })" 
                               class="btn btn-primary">
                                <i class="bi bi-house"></i> Về trang chủ
                            </a>
                        }
                        else
                        {
                            <a href="/" class="btn btn-primary">
                                <i class="bi bi-house"></i> Về trang chủ
                            </a>
                        }
                        <a href="/Account/Logout" class="btn btn-outline-secondary">
                            <i class="bi bi-box-arrow-right"></i> Đăng xuất
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
