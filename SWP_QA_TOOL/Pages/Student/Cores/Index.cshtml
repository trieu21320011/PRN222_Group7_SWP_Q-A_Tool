@page
@model SWP_QA_TOOL.Pages.Student.Cores.IndexModel
@{
    ViewData["Title"] = "Lớp của tôi";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <h3><i class="bi bi-collection"></i> Lớp của tôi</h3>
            <p class="text-muted">Xem thông tin lớp mà bạn thuộc về</p>
        </div>
    </div>

    <div class="row">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="bi bi-collection-fill"></i> SE1234 - Lớp A Sáng</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <p><strong><i class="bi bi-journal-bookmark"></i> Đề tài:</strong></p>
                            <p class="ms-3">SWP391 - Phát triển phần mềm</p>
                            
                            <p><strong><i class="bi bi-calendar"></i> Học kỳ:</strong></p>
                            <p class="ms-3">Fall 2024 (01/09/2024 - 31/12/2024)</p>
                            
                            <p><strong><i class="bi bi-person-badge"></i> Giảng viên hướng dẫn:</strong></p>
                            <p class="ms-3">ThS. Nguyễn Văn Instructor</p>
                        </div>
                        <div class="col-md-6">
                            <p><strong><i class="bi bi-hash"></i> Mã lớp:</strong></p>
                            <p class="ms-3">SE1234</p>
                            
                            <p><strong><i class="bi bi-people"></i> Số nhóm trong lớp:</strong></p>
                            <p class="ms-3">4 nhóm</p>
                            
                            <p><strong><i class="bi bi-clock"></i> Lịch họp:</strong></p>
                            <p class="ms-3">Thứ 2, 4, 6 - 7:00 - 9:30</p>
                            
                            <p><strong><i class="bi bi-geo-alt"></i> Phòng học:</strong></p>
                            <p class="ms-3">DE-C303</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card">
                <div class="card-header bg-light">
                    <h6 class="mb-0"><i class="bi bi-info-circle"></i> Thông tin nhanh</h6>
                </div>
                <div class="card-body">
                    <div class="d-flex justify-content-between mb-2">
                        <span>Số câu hỏi đã gửi:</span>
                        <span class="badge bg-info">5</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span>Đã được trả lời:</span>
                        <span class="badge bg-success">3</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span>Đang chờ:</span>
                        <span class="badge bg-warning">2</span>
                    </div>
                    <hr>
                    <div class="d-flex justify-content-between mb-2">
                        <span>Tiến độ nhóm:</span>
                        <span class="badge bg-success">85%</span>
                    </div>
                </div>
            </div>

            <div class="card mt-3">
                <div class="card-header bg-light">
                    <h6 class="mb-0"><i class="bi bi-people"></i> Các nhóm khác trong lớp</h6>
                </div>
                <div class="list-group list-group-flush">
                    <div class="list-group-item">
                        <div class="d-flex justify-content-between">
                            <span>Nhóm 1 (Nhóm của tôi)</span>
                            <span class="badge bg-success">85%</span>
                        </div>
                    </div>
                    <div class="list-group-item">
                        <div class="d-flex justify-content-between">
                            <span>Nhóm 2</span>
                            <span class="badge bg-info">70%</span>
                        </div>
                    </div>
                    <div class="list-group-item">
                        <div class="d-flex justify-content-between">
                            <span>Nhóm 3</span>
                            <span class="badge bg-warning">60%</span>
                        </div>
                    </div>
                    <div class="list-group-item">
                        <div class="d-flex justify-content-between">
                            <span>Nhóm 4</span>
                            <span class="badge bg-warning">55%</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
