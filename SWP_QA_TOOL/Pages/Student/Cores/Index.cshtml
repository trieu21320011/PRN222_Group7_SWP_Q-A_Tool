@page
@model SWP_QA_TOOL.Pages.Student.Cores.IndexModel
@{
    ViewData["Title"] = "Lớp của tôi";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-page="/Student/Index">Trang chủ</a></li>
                    <li class="breadcrumb-item active">Lớp của tôi</li>
                </ol>
            </nav>
            <h3><i class="bi bi-collection"></i> Lớp của tôi</h3>
            <p class="text-muted">Danh sách các lớp bạn đang tham gia trong học kỳ hiện tại</p>
        </div>
    </div>

    <div class="alert alert-info">
        <i class="bi bi-info-circle"></i> Bạn đang tham gia <strong>@Model.MyCores.Count()</strong> lớp
    </div>

    <div class="row">
        @if (Model.MyCores.Any())
        {
            @foreach (var core in Model.MyCores)
            {
                <div class="col-md-6 mb-4">
                    <div class="card h-100">
                        <div class="card-header bg-primary text-white">
                            <h5 class="mb-0"><i class="bi bi-collection-fill"></i> @core.CoreCode - @core.CoreName</h5>
                        </div>
                        <div class="card-body">
                            <div class="row">
                                <div class="col-md-6">
                                    <p><strong><i class="bi bi-person-badge"></i> Giảng viên:</strong></p>
                                    <p class="ms-3">@(core.InstructorName ?? "Chưa xác định")</p>
                                    
                                    <p><strong><i class="bi bi-calendar"></i> Học kỳ:</strong></p>
                                    <p class="ms-3">@(core.SemesterCode ?? "N/A")</p>
                                </div>
                                <div class="col-md-6">
                                    <p><strong><i class="bi bi-clock"></i> Lịch học:</strong></p>
                                    <p class="ms-3">@(core.Schedule ?? "Chưa xác định")</p>
                                    
                                    <p><strong><i class="bi bi-geo-alt"></i> Phòng học:</strong></p>
                                    <p class="ms-3">@(core.Room ?? "Chưa xác định")</p>
                                </div>
                            </div>
                        </div>
                        <div class="card-footer bg-light">
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="badge @(core.IsActive == true ? "bg-success" : "bg-secondary")">
                                    @(core.IsActive == true ? "Đang hoạt động" : "Đã kết thúc")
                                </span>
                                <a asp-page="/Student/Teams/MyTeam" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-people"></i> Xem nhóm
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <div class="alert alert-warning text-center">
                    <i class="bi bi-exclamation-triangle"></i> Bạn chưa tham gia lớp nào trong học kỳ hiện tại.
                    <br>
                    <a asp-page="/Student/Teams/Create" class="btn btn-success mt-3">
                        <i class="bi bi-plus-circle"></i> Tạo nhóm và đăng ký lớp
                    </a>
                </div>
            </div>
        }
    </div>
</div>
