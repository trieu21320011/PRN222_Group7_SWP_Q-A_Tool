@page
@model SWP_QA_TOOL.Pages.Student.ChatModel
@{
    ViewData["Title"] = "Tin nhắn";
}

<style>
    .chat-container {
        height: 70vh;
        max-height: 600px;
        min-height: 400px;
    }
    .chat-sidebar {
        height: 100%;
        display: flex;
        flex-direction: column;
    }
    .chat-sidebar .card-body {
        flex: 1;
        overflow-y: auto;
        min-height: 0;
    }
    .chat-main {
        height: 100%;
        display: flex;
        flex-direction: column;
    }
    .chat-main .card {
        height: 100%;
        display: flex;
        flex-direction: column;
    }
    .chat-main .card-body {
        flex: 1;
        overflow-y: auto;
        min-height: 0;
    }
</style>

<div class="container-fluid">
    <div class="row mb-3">
        <div class="col-12">
            <h2><i class="bi bi-chat-dots"></i> Tin nhắn với Giảng viên</h2>
            <p class="text-muted">Liên hệ với giảng viên hướng dẫn của bạn</p>
        </div>
    </div>

    <div class="row chat-container">
        <!-- Sidebar - Teacher List & Chat Rooms -->
        <div class="col-md-4 col-lg-3 chat-sidebar">
            <div class="card h-100">
                <div class="card-header bg-primary text-white">
                    <h6 class="mb-0"><i class="bi bi-people-fill"></i> Danh sách liên hệ</h6>
                </div>
                <div class="card-body p-0" style="overflow-y: auto;">
                    <!-- Available Teachers from Cores -->
                    @if (Model.AvailableTeachers.Any())
                    {
                        <div class="p-2 bg-light border-bottom">
                            <small class="text-muted fw-bold">Giảng viên của tôi</small>
                        </div>
                        @foreach (var teacher in Model.AvailableTeachers)
                        {
                            var isSelected = Model.SelectedTeacherId == teacher.UserId || 
                                (Model.SelectedChatRoom?.OtherUserId == teacher.UserId);
                            <a href="?teacherId=@teacher.UserId" 
                               class="list-group-item list-group-item-action border-0 @(isSelected ? "active" : "")">
                                <div class="d-flex align-items-center">
                                    <div class="flex-shrink-0">
                                        @if (!string.IsNullOrEmpty(teacher.AvatarUrl))
                                        {
                                            <img src="@teacher.AvatarUrl" class="rounded-circle" width="40" height="40" alt="Avatar">
                                        }
                                        else
                                        {
                                            <div class="rounded-circle bg-secondary d-flex align-items-center justify-content-center" 
                                                 style="width: 40px; height: 40px;">
                                                <i class="bi bi-person text-white"></i>
                                            </div>
                                        }
                                    </div>
                                    <div class="flex-grow-1 ms-2">
                                        <h6 class="mb-0 text-truncate">@(teacher.DisplayName ?? teacher.FullName)</h6>
                                        <small class="@(isSelected ? "text-white-50" : "text-muted")">@teacher.CoreCode - @teacher.CoreName</small>
                                    </div>
                                </div>
                            </a>
                        }
                    }

                    <!-- Existing Chat Rooms -->
                    @if (Model.ChatRooms.Any())
                    {
                        <div class="p-2 bg-light border-bottom border-top">
                            <small class="text-muted fw-bold">Cuộc trò chuyện gần đây</small>
                        </div>
                        @foreach (var room in Model.ChatRooms.Where(r => !Model.AvailableTeachers.Any(t => t.UserId == r.OtherUserId)))
                        {
                            var isSelected = Model.SelectedChatRoomId == room.ChatRoomId;
                            <a href="?chatRoomId=@room.ChatRoomId" 
                               class="list-group-item list-group-item-action border-0 @(isSelected ? "active" : "")">
                                <div class="d-flex align-items-center">
                                    <div class="flex-shrink-0">
                                        @if (!string.IsNullOrEmpty(room.OtherUserAvatar))
                                        {
                                            <img src="@room.OtherUserAvatar" class="rounded-circle" width="40" height="40" alt="Avatar">
                                        }
                                        else
                                        {
                                            <div class="rounded-circle bg-info d-flex align-items-center justify-content-center" 
                                                 style="width: 40px; height: 40px;">
                                                <i class="bi bi-person text-white"></i>
                                            </div>
                                        }
                                    </div>
                                    <div class="flex-grow-1 ms-2">
                                        <h6 class="mb-0 text-truncate">@room.OtherUserName</h6>
                                        @if (room.LastMessage != null)
                                        {
                                            <small class="@(isSelected ? "text-white-50" : "text-muted") text-truncate d-block">
                                                @(room.LastMessage.MessageText.Length > 30 
                                                    ? room.LastMessage.MessageText.Substring(0, 30) + "..." 
                                                    : room.LastMessage.MessageText)
                                            </small>
                                        }
                                    </div>
                                </div>
                            </a>
                        }
                    }

                    @if (!Model.AvailableTeachers.Any() && !Model.ChatRooms.Any())
                    {
                        <div class="p-4 text-center text-muted">
                            <i class="bi bi-chat-square-text" style="font-size: 3rem;"></i>
                            <p class="mt-2">Bạn chưa được thêm vào lớp học nào.<br>Hãy liên hệ quản trị viên.</p>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Chat Area -->
        <div class="col-md-8 col-lg-9 chat-main">
            <div class="card h-100">
                @if (Model.SelectedChatRoom != null)
                {
                    <!-- Chat Header -->
                    <div class="card-header bg-white border-bottom d-flex align-items-center">
                        @if (!string.IsNullOrEmpty(Model.SelectedChatRoom.OtherUserAvatar))
                        {
                            <img src="@Model.SelectedChatRoom.OtherUserAvatar" class="rounded-circle me-2" width="40" height="40" alt="Avatar">
                        }
                        else
                        {
                            <div class="rounded-circle bg-primary d-flex align-items-center justify-content-center me-2" 
                                 style="width: 40px; height: 40px;">
                                <i class="bi bi-person text-white"></i>
                            </div>
                        }
                        <div>
                            <h6 class="mb-0">@Model.SelectedChatRoom.OtherUserName</h6>
                            <small class="text-muted" id="typingIndicator" style="display: none;">Đang nhập...</small>
                        </div>
                    </div>

                    <!-- Messages Container -->
                    <div class="card-body p-3" id="messagesContainer" style="overflow-y: auto; flex: 1;">
                        @foreach (var message in Model.Messages)
                        {
                            <div class="d-flex mb-3 @(message.IsOwnMessage ? "justify-content-end" : "justify-content-start")">
                                <div class="@(message.IsOwnMessage ? "bg-primary text-white" : "bg-light")" 
                                     style="max-width: 70%; padding: 10px 15px; border-radius: 15px;">
                                    <p class="mb-1">@message.MessageText</p>
                                    <small class="@(message.IsOwnMessage ? "text-white-50" : "text-muted")">
                                        @message.CreatedAt?.ToString("HH:mm dd/MM")
                                        @if (message.IsEdited == true)
                                        {
                                            <span>(đã chỉnh sửa)</span>
                                        }
                                    </small>
                                </div>
                            </div>
                        }
                    </div>

                    <!-- Message Input -->
                    <div class="card-footer bg-white">
                        <form id="messageForm" class="d-flex gap-2">
                            <input type="hidden" id="chatRoomId" value="@Model.SelectedChatRoomId" />
                            <input type="text" id="messageInput" class="form-control" 
                                   placeholder="Nhập tin nhắn..." autocomplete="off" />
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-send"></i>
                            </button>
                        </form>
                    </div>
                }
                else
                {
                    <!-- No Chat Selected -->
                    <div class="card-body d-flex flex-column align-items-center justify-content-center text-muted">
                        <i class="bi bi-chat-left-text" style="font-size: 5rem;"></i>
                        <h5 class="mt-3">Chọn một giảng viên để bắt đầu trò chuyện</h5>
                        <p>Nhấn vào tên giảng viên ở bên trái để gửi tin nhắn</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.0/signalr.min.js"></script>
    <script>
        const chatRoomId = document.getElementById('chatRoomId')?.value;
        const currentUserId = @Model.CurrentUserId;
        let connection = null;
        let typingTimeout = null;

        // Initialize SignalR connection
        if (chatRoomId) {
            connection = new signalR.HubConnectionBuilder()
                .withUrl("/chatHub")
                .withAutomaticReconnect()
                .build();

            // Handle received messages
            connection.on("ReceiveMessage", function (message) {
                appendMessage(message);
                scrollToBottom();
            });

            // Handle typing indicator
            connection.on("UserTyping", function (data) {
                document.getElementById('typingIndicator').style.display = 'block';
            });

            connection.on("UserStoppedTyping", function (userId) {
                document.getElementById('typingIndicator').style.display = 'none';
            });

            // Handle message deleted
            connection.on("MessageDeleted", function (messageId) {
                const messageEl = document.querySelector(`[data-message-id="${messageId}"]`);
                if (messageEl) {
                    messageEl.remove();
                }
            });

            // Handle message edited
            connection.on("MessageEdited", function (message) {
                const messageEl = document.querySelector(`[data-message-id="${message.chatMessageId}"]`);
                if (messageEl) {
                    messageEl.querySelector('p').textContent = message.messageText;
                }
            });

            // Handle new message notification
            connection.on("NewMessageNotification", function (data) {
                // Show browser notification if available
                if (Notification.permission === "granted") {
                    new Notification(data.senderName, {
                        body: data.messagePreview,
                        icon: '/favicon.ico'
                    });
                }
            });

            // Start connection
            connection.start()
                .then(function () {
                    console.log("SignalR Connected");
                    // Join the chat room
                    connection.invoke("JoinRoom", parseInt(chatRoomId));
                })
                .catch(function (err) {
                    console.error("SignalR Connection Error: ", err);
                });

            // Request notification permission
            if (Notification.permission === "default") {
                Notification.requestPermission();
            }
        }

        // Send message form handler
        document.getElementById('messageForm')?.addEventListener('submit', function (e) {
            e.preventDefault();
            const messageInput = document.getElementById('messageInput');
            const message = messageInput.value.trim();

            if (message && connection) {
                connection.invoke("SendMessage", parseInt(chatRoomId), message, "Text", null)
                    .then(function () {
                        messageInput.value = '';
                        connection.invoke("StopTyping", parseInt(chatRoomId));
                    })
                    .catch(function (err) {
                        console.error("Error sending message: ", err);
                        alert("Không thể gửi tin nhắn. Vui lòng thử lại.");
                    });
            }
        });

        // Typing indicator
        document.getElementById('messageInput')?.addEventListener('input', function () {
            if (connection) {
                connection.invoke("SendTyping", parseInt(chatRoomId));

                clearTimeout(typingTimeout);
                typingTimeout = setTimeout(function () {
                    connection.invoke("StopTyping", parseInt(chatRoomId));
                }, 2000);
            }
        });

        // Append message to chat
        function appendMessage(message) {
            const container = document.getElementById('messagesContainer');
            const isOwn = message.senderId === currentUserId;

            const messageHtml = `
                <div class="d-flex mb-3 ${isOwn ? 'justify-content-end' : 'justify-content-start'}" data-message-id="${message.chatMessageId}">
                    <div class="${isOwn ? 'bg-primary text-white' : 'bg-light'}" 
                         style="max-width: 70%; padding: 10px 15px; border-radius: 15px;">
                        <p class="mb-1">${escapeHtml(message.messageText)}</p>
                        <small class="${isOwn ? 'text-white-50' : 'text-muted'}">
                            ${formatDate(message.createdAt)}
                        </small>
                    </div>
                </div>
            `;

            container.insertAdjacentHTML('beforeend', messageHtml);
        }

        // Scroll to bottom of messages
        function scrollToBottom() {
            const container = document.getElementById('messagesContainer');
            if (container) {
                container.scrollTop = container.scrollHeight;
            }
        }

        // Format date
        function formatDate(dateString) {
            if (!dateString) return '';
            const date = new Date(dateString);
            return date.toLocaleString('vi-VN', {
                hour: '2-digit',
                minute: '2-digit',
                day: '2-digit',
                month: '2-digit'
            });
        }

        // Escape HTML to prevent XSS
        function escapeHtml(text) {
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }

        // Scroll to bottom on page load
        document.addEventListener('DOMContentLoaded', function () {
            scrollToBottom();
        });
    </script>
}
