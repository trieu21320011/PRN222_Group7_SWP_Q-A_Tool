@page
@model SWP_QA_TOOL.Pages.Student.Questions.IndexModel
@{
    ViewData["Title"] = "Câu hỏi của tôi";
    var pendingCount = Model.MyQuestions.Count(q => q.Status == "Open" || q.Status == "Pending");
    var answeredCount = Model.MyQuestions.Count(q => q.AnswerCount > 0 && !q.IsClosed.GetValueOrDefault());
    var resolvedCount = Model.MyQuestions.Count(q => q.IsClosed.GetValueOrDefault());
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <h3><i class="bi bi-question-circle"></i> Câu hỏi của tôi</h3>
            <p class="text-muted">Xem tất cả câu hỏi bạn đã gửi cho giảng viên</p>
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-md-8">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-page="/Student/Index">Trang chủ</a></li>
                    <li class="breadcrumb-item active">Câu hỏi của tôi</li>
                </ol>
            </nav>
        </div>
        <div class="col-md-4 text-end">
            <a asp-page="/Student/Questions/Create" class="btn btn-success">
                <i class="bi bi-plus-circle"></i> Tạo câu hỏi mới
            </a>
        </div>
    </div>

    <!-- Thống kê nhanh -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card border-warning">
                <div class="card-body text-center py-2">
                    <h4 class="text-warning mb-0">@pendingCount</h4>
                    <small>Chờ trả lời</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-success">
                <div class="card-body text-center py-2">
                    <h4 class="text-success mb-0">@answeredCount</h4>
                    <small>Đã trả lời</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-primary">
                <div class="card-body text-center py-2">
                    <h4 class="text-primary mb-0">@resolvedCount</h4>
                    <small>Đã giải quyết</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-info">
                <div class="card-body text-center py-2">
                    <h4 class="text-info mb-0">@Model.MyQuestions.Count</h4>
                    <small>Tổng câu hỏi</small>
                </div>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            @if (Model.MyQuestions.Any())
            {
                <table class="table table-hover">
                    <thead class="table-light">
                        <tr>
                            <th>#</th>
                            <th>Tiêu đề</th>
                            <th>Lớp</th>
                            <th>Thời gian</th>
                            <th>Trạng thái</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            var index = 1;
                        }
                        @foreach (var question in Model.MyQuestions.OrderByDescending(q => q.CreatedAt))
                        {
                            var isPending = question.Status == "Open" || question.Status == "Pending";
                            var isAnswered = question.AnswerCount > 0 && !question.IsClosed.GetValueOrDefault();
                            var isResolved = question.IsClosed.GetValueOrDefault();
                            <tr class="@(isPending ? "table-warning" : "")">
                                <td>@(index++)</td>
                                <td>
                                    <a asp-page="/Student/Questions/Details" asp-route-id="@question.QuestionId" class="text-decoration-none">
                                        <strong>@question.Title</strong>
                                        @if (isAnswered && !isResolved)
                                        {
                                            <span class="badge bg-success ms-1">Mới TL</span>
                                        }
                                    </a>
                                </td>
                                <td>@(question.CoreName ?? "-")</td>
                                <td>@(question.CreatedAt?.ToString("dd/MM/yyyy HH:mm") ?? "-")</td>
                                <td>
                                    @if (isResolved)
                                    {
                                        <span class="badge bg-primary">Đã giải quyết</span>
                                    }
                                    else if (isAnswered)
                                    {
                                        <span class="badge bg-success">Đã trả lời</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning">Chờ trả lời</span>
                                    }
                                </td>
                                <td>
                                    <a asp-page="/Student/Questions/Details" asp-route-id="@question.QuestionId" class="btn btn-sm btn-outline-primary" title="Xem chi tiết">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    @if (!isResolved)
                                    {
                                        <a asp-page="/Student/Questions/Edit" asp-route-id="@question.QuestionId" class="btn btn-sm btn-outline-secondary" title="Chỉnh sửa">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="bi bi-question-circle text-muted" style="font-size: 3rem;"></i>
                    <p class="text-muted mt-3">Bạn chưa có câu hỏi nào.</p>
                    <a asp-page="/Student/Questions/Create" class="btn btn-success">
                        <i class="bi bi-plus-circle"></i> Tạo câu hỏi đầu tiên
                    </a>
                </div>
            }
        </div>
    </div>
</div>
