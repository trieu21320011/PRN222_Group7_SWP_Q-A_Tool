@page "{id:int?}"
@model SWP_QA_TOOL.Pages.Student.Questions.DetailsModel
@{
    ViewData["Title"] = "Chi tiết câu hỏi";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/Student/Index">Trang chủ</a></li>
                    <li class="breadcrumb-item"><a href="/Student/Questions/Index">Câu hỏi</a></li>
                    <li class="breadcrumb-item active">Chi tiết</li>
                </ol>
            </nav>
        </div>
    </div>

    <div class="row">
        <div class="col-md-8">
            <!-- Câu hỏi -->
            <div class="card mb-4">
                <div class="card-header bg-warning text-dark d-flex justify-content-between align-items-center">
                    <h5 class="mb-0"><i class="bi bi-question-circle"></i> Câu hỏi về Use Case Diagram</h5>
                    <span class="badge bg-warning text-dark">Chờ trả lời</span>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <span class="badge bg-info">Nhóm 1</span>
                        <span class="badge bg-secondary">Core A</span>
                        <span class="badge bg-primary">Requirements</span>
                    </div>
                    <p class="text-muted">
                        <i class="bi bi-person"></i> Hỏi bởi: <strong>Nguyễn Văn A</strong> - 
                        <i class="bi bi-clock"></i> 10 phút trước
                    </p>
                    <hr>
                    <div class="question-content">
                        <p>Kính gửi Thầy/Cô,</p>
                        <p>Em muốn hỏi về cách vẽ Use Case Diagram cho chức năng đăng nhập, đăng ký trong dự án. Cụ thể:</p>
                        <ol>
                            <li>Actor "User" có nên được chia thành "Guest" và "Member" không?</li>
                            <li>Chức năng "Quên mật khẩu" nên được đặt là extend hay include của "Đăng nhập"?</li>
                            <li>Có cần vẽ riêng Use Case cho validate form không?</li>
                        </ol>
                        <p>Em xin cảm ơn Thầy/Cô!</p>
                    </div>
                </div>
                <div class="card-footer bg-white">
                    <a href="/Student/Questions/Edit" class="btn btn-sm btn-outline-secondary">
                        <i class="bi bi-pencil"></i> Chỉnh sửa
                    </a>
                    <button class="btn btn-sm btn-outline-danger">
                        <i class="bi bi-trash"></i> Xóa
                    </button>
                </div>
            </div>

            <!-- Câu trả lời (nếu có) -->
            <div class="card mb-4 border-success">
                <div class="card-header bg-success text-white">
                    <h6 class="mb-0"><i class="bi bi-chat-right-quote"></i> Câu trả lời từ Giảng viên</h6>
                </div>
                <div class="card-body">
                    <p class="text-muted mb-2">
                        <i class="bi bi-person-badge"></i> <strong>ThS. Nguyễn Văn Instructor</strong> - 
                        <i class="bi bi-clock"></i> 30 phút trước
                    </p>
                    <hr>
                    <div class="answer-content">
                        <p>Chào em,</p>
                        <p>Về các câu hỏi của em:</p>
                        <ol>
                            <li><strong>Chia Actor:</strong> Đúng rồi em, nên chia thành Guest (chưa đăng nhập) và Member (đã đăng nhập) để phân biệt rõ quyền truy cập.</li>
                            <li><strong>Quên mật khẩu:</strong> Nên dùng EXTEND vì đây là chức năng tùy chọn, chỉ xảy ra khi user cần.</li>
                            <li><strong>Validate form:</strong> Không cần vẽ riêng, validation được hiểu là một phần của mỗi use case có form input.</li>
                        </ol>
                        <p>Chúc em làm bài tốt!</p>
                    </div>
                </div>
                <div class="card-footer bg-white">
                    <div class="d-flex justify-content-between align-items-center">
                        <small class="text-muted">Câu trả lời có hữu ích không?</small>
                        <div>
                            <button class="btn btn-sm btn-outline-success">
                                <i class="bi bi-check-circle"></i> Đánh dấu đã giải quyết
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Bình luận thêm -->
            <div class="card">
                <div class="card-header bg-light">
                    <h6 class="mb-0"><i class="bi bi-chat-dots"></i> Bình luận / Hỏi thêm</h6>
                </div>
                <div class="card-body">
                    <div class="mb-3 p-3 bg-light rounded">
                        <p class="mb-1"><strong>Nguyễn Văn A</strong> <small class="text-muted">- 5 phút trước</small></p>
                        <p class="mb-0">Em cảm ơn Thầy ạ. Em có thêm một thắc mắc nữa về System Boundary...</p>
                    </div>

                    <form method="post">
                        <div class="mb-3">
                            <label class="form-label">Thêm bình luận</label>
                            <textarea class="form-control" rows="3" placeholder="Nhập bình luận hoặc câu hỏi thêm..."></textarea>
                        </div>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-send"></i> Gửi bình luận
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card mb-3">
                <div class="card-header bg-light">
                    <h6 class="mb-0"><i class="bi bi-info-circle"></i> Thông tin câu hỏi</h6>
                </div>
                <div class="card-body">
                    <p><strong>Mã câu hỏi:</strong> #Q001</p>
                    <p><strong>Trạng thái:</strong> <span class="badge bg-warning">Chờ trả lời</span></p>
                    <p><strong>Phân loại:</strong> Requirements</p>
                    <p><strong>Ưu tiên:</strong> <span class="badge bg-secondary">Bình thường</span></p>
                    <p><strong>Ngày tạo:</strong> 20/10/2024, 10:30</p>
                    <p><strong>Cập nhật:</strong> 20/10/2024, 11:00</p>
                </div>
            </div>

            <div class="card mb-3">
                <div class="card-header bg-light">
                    <h6 class="mb-0"><i class="bi bi-people"></i> Thông tin nhóm</h6>
                </div>
                <div class="card-body">
                    <p><strong>Nhóm:</strong> Nhóm 1</p>
                    <p><strong>Core:</strong> Core A - Morning</p>
                    <p><strong>GV hướng dẫn:</strong> ThS. Nguyễn Văn Instructor</p>
                </div>
            </div>

            <div class="card">
                <div class="card-header bg-light">
                    <h6 class="mb-0"><i class="bi bi-paperclip"></i> File đính kèm</h6>
                </div>
                <div class="list-group list-group-flush">
                    <a href="#" class="list-group-item list-group-item-action">
                        <i class="bi bi-file-earmark-image text-primary"></i> use_case_draft.png
                        <small class="text-muted">(256 KB)</small>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
