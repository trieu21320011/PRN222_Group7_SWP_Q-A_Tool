@page "{id:int}"
@model SWP_QA_TOOL.Pages.Student.Questions.DetailsModel
@{
    ViewData["Title"] = Model.Question?.Title ?? "Chi tiết câu hỏi";
    var isPending = Model.Question?.Status == "Open" || Model.Question?.Status == "Pending";
    var isAnswered = Model.Answers.Any();
    var isResolved = Model.Question?.IsClosed ?? false;
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-page="/Student/Index">Trang chủ</a></li>
                    <li class="breadcrumb-item"><a asp-page="/Student/Questions/Index">Câu hỏi</a></li>
                    <li class="breadcrumb-item active">Chi tiết</li>
                </ol>
            </nav>
        </div>
    </div>

    @if (TempData["SuccessMessage"] is string successMessage)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @successMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] is string errorMessage)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @errorMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (Model.Question == null)
    {
        <div class="alert alert-warning">Không tìm thấy câu hỏi.</div>
    }
    else
    {
        <div class="row">
            <div class="col-md-8">
                <!-- Câu hỏi -->
                <div class="card mb-4">
                    <div class="card-header @(isPending ? "bg-warning text-dark" : isResolved ? "bg-primary text-white" : "bg-success text-white") d-flex justify-content-between align-items-center">
                        <h5 class="mb-0"><i class="bi bi-question-circle"></i> @Model.Question.Title</h5>
                        @if (isResolved)
                        {
                            <span class="badge bg-white text-primary">Đã giải quyết</span>
                        }
                        else if (isAnswered)
                        {
                            <span class="badge bg-white text-success">Đã trả lời</span>
                        }
                        else
                        {
                            <span class="badge bg-dark">Chờ trả lời</span>
                        }
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            @if (!string.IsNullOrEmpty(Model.Question.TeamName))
                            {
                                <span class="badge bg-info">@Model.Question.TeamName</span>
                            }
                            @if (!string.IsNullOrEmpty(Model.Question.CoreName))
                            {
                                <span class="badge bg-secondary">@Model.Question.CoreName</span>
                            }
                            @if (!string.IsNullOrEmpty(Model.Question.Category))
                            {
                                <span class="badge bg-primary">@Model.Question.Category</span>
                            }
                        </div>
                        <p class="text-muted">
                            <i class="bi bi-person"></i> Hỏi bởi: <strong>@(Model.Question.AuthorName ?? "Ẩn danh")</strong> - 
                            <i class="bi bi-clock"></i> @(Model.Question.CreatedAt?.ToString("dd/MM/yyyy HH:mm") ?? "-")
                        </p>
                        <hr>
                        <div class="question-content">
                            @Html.Raw(Model.Question.Body?.Replace("\n", "<br>"))
                        </div>
                    </div>
                    @if (!isResolved)
                    {
                        <div class="card-footer bg-white">
                            <a asp-page="/Student/Questions/Edit" asp-route-id="@Model.Question.QuestionId" class="btn btn-sm btn-outline-secondary">
                                <i class="bi bi-pencil"></i> Chỉnh sửa
                            </a>
                        </div>
                    }
                </div>

                <!-- Comments on Question (Follow-up questions) -->
                @if (Model.QuestionComments.Any())
                {
                    <div class="card mb-4 border-info">
                        <div class="card-header bg-info text-white">
                            <h6 class="mb-0"><i class="bi bi-chat-dots"></i> Hỏi thêm (@Model.QuestionComments.Count)</h6>
                        </div>
                        <div class="card-body">
                            @foreach (var comment in Model.QuestionComments.OrderBy(c => c.CreatedAt))
                            {
                                <div class="border-start border-info border-3 ps-3 mb-3">
                                    <p class="mb-1">@comment.Body</p>
                                    <small class="text-muted">
                                        <i class="bi bi-person"></i> @(comment.AuthorName ?? "Ẩn danh") - 
                                        <i class="bi bi-clock"></i> @(comment.CreatedAt?.ToString("dd/MM/yyyy HH:mm") ?? "-")
                                        @if (comment.IsEdited == true)
                                        {
                                            <span class="text-warning">(đã chỉnh sửa)</span>
                                        }
                                    </small>
                                </div>
                            }
                        </div>
                    </div>
                }

                <!-- Form to add follow-up question -->
                @if (!isResolved)
                {
                    <div class="card mb-4 border-secondary">
                        <div class="card-header bg-secondary text-white">
                            <h6 class="mb-0"><i class="bi bi-plus-circle"></i> Hỏi thêm về câu hỏi này</h6>
                        </div>
                        <div class="card-body">
                            <form method="post" asp-page-handler="AddQuestionComment" asp-route-id="@Model.Question.QuestionId">
                                <div class="mb-3">
                                    <textarea asp-for="NewComment" class="form-control" rows="3" placeholder="Nhập câu hỏi thêm của bạn..." required></textarea>
                                </div>
                                <button type="submit" class="btn btn-info">
                                    <i class="bi bi-send"></i> Gửi câu hỏi thêm
                                </button>
                            </form>
                        </div>
                    </div>
                }

                <!-- Câu trả lời -->
                @if (Model.Answers.Any())
                {
                    @foreach (var answer in Model.Answers)
                    {
                        var isMentorAns = answer.IsMentorAnswer ?? false;
                        var isAcceptedAns = answer.IsAccepted ?? false;
                        <div class="card mb-4 @(isMentorAns ? "border-success" : "")">
                            <div class="card-header @(isMentorAns ? "bg-success text-white" : "bg-light")">
                                <h6 class="mb-0">
                                    <i class="bi bi-chat-right-quote"></i>
                                    @if (isMentorAns)
                                    {
                                        <span>Câu trả lời từ Giảng viên</span>
                                    }
                                    else
                                    {
                                        <span>Câu trả lời</span>
                                    }
                                    @if (isAcceptedAns)
                                    {
                                        <span class="badge bg-success ms-2"><i class="bi bi-check-circle"></i> Accepted</span>
                                    }
                                </h6>
                            </div>
                            <div class="card-body">
                                <p class="text-muted mb-2">
                                    <i class="bi bi-person-badge"></i> <strong>@(answer.AuthorName ?? "Ẩn danh")</strong> - 
                                    <i class="bi bi-clock"></i> @(answer.CreatedAt?.ToString("dd/MM/yyyy HH:mm") ?? "-")
                                </p>
                                <hr>
                                <div class="answer-content">
                                    @Html.Raw(answer.Body?.Replace("\n", "<br>"))
                                </div>

                                <!-- Comments on this answer -->
                                @if (Model.AnswerComments.ContainsKey(answer.AnswerId) && Model.AnswerComments[answer.AnswerId].Any())
                                {
                                    <hr>
                                    <div class="mt-3">
                                        <h6 class="text-info"><i class="bi bi-chat-dots"></i> Hỏi thêm (@Model.AnswerComments[answer.AnswerId].Count)</h6>
                                        @foreach (var comment in Model.AnswerComments[answer.AnswerId].OrderBy(c => c.CreatedAt))
                                        {
                                            <div class="border-start border-info border-3 ps-3 mb-2 ms-3">
                                                <p class="mb-1">@comment.Body</p>
                                                <small class="text-muted">
                                                    <i class="bi bi-person"></i> @(comment.AuthorName ?? "Ẩn danh") - 
                                                    <i class="bi bi-clock"></i> @(comment.CreatedAt?.ToString("dd/MM/yyyy HH:mm") ?? "-")
                                                </small>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                            @if (!isResolved && isMentorAns)
                            {
                                <div class="card-footer bg-white">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <small class="text-muted">Câu trả lời có hữu ích không?</small>
                                        <form method="post" asp-page-handler="MarkAsResolved" asp-route-id="@Model.Question.QuestionId">
                                            <button type="submit" class="btn btn-sm btn-outline-success">
                                                <i class="bi bi-check-circle"></i> Đánh dấu đã hiểu
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            }

                            <!-- Form to add comment to this answer -->
                            @if (!isResolved)
                            {
                                <div class="card-footer bg-light">
                                    <form method="post" asp-page-handler="AddAnswerComment" asp-route-id="@Model.Question.QuestionId" asp-route-answerId="@answer.AnswerId">
                                        <div class="input-group">
                                            <input type="text" asp-for="NewComment" class="form-control form-control-sm" placeholder="Hỏi thêm về câu trả lời này..." />
                                            <button type="submit" class="btn btn-sm btn-info">
                                                <i class="bi bi-send"></i>
                                            </button>
                                        </div>
                                    </form>
                                </div>
                            }
                        </div>
                    }
                }
                else
                {
                    <div class="card mb-4">
                        <div class="card-body text-center text-muted py-5">
                            <i class="bi bi-chat-left-dots" style="font-size: 3rem;"></i>
                            <p class="mt-3">Chưa có câu trả lời nào. Giảng viên sẽ phản hồi sớm nhất có thể.</p>
                        </div>
                    </div>
                }
            </div>

            <div class="col-md-4">
                <div class="card mb-3">
                    <div class="card-header bg-light">
                        <h6 class="mb-0"><i class="bi bi-info-circle"></i> Thông tin câu hỏi</h6>
                    </div>
                    <div class="card-body">
                        <p><strong>Mã câu hỏi:</strong> #Q@Model.Question.QuestionId</p>
                        <p><strong>Trạng thái:</strong> 
                            @if (isResolved)
                            {
                                <span class="badge bg-primary">Đã giải quyết</span>
                            }
                            else if (isAnswered)
                            {
                                <span class="badge bg-success">Đã trả lời</span>
                            }
                            else
                            {
                                <span class="badge bg-warning">Chờ trả lời</span>
                            }
                        </p>
                        @if (!string.IsNullOrEmpty(Model.Question.Category))
                        {
                            <p><strong>Phân loại:</strong> @Model.Question.Category</p>
                        }
                        @if (!string.IsNullOrEmpty(Model.Question.Difficulty))
                        {
                            <p><strong>Độ khó:</strong> @Model.Question.Difficulty</p>
                        }
                        <p><strong>Ngày tạo:</strong> @(Model.Question.CreatedAt?.ToString("dd/MM/yyyy HH:mm") ?? "-")</p>
                        @if (Model.Question.ViewCount > 0)
                        {
                            <p><strong>Lượt xem:</strong> @Model.Question.ViewCount</p>
                        }
                    </div>
                </div>

                <div class="card mb-3">
                    <div class="card-header bg-light">
                        <h6 class="mb-0"><i class="bi bi-people"></i> Thông tin liên quan</h6>
                    </div>
                    <div class="card-body">
                        @if (!string.IsNullOrEmpty(Model.Question.TeamName))
                        {
                            <p><strong>Nhóm:</strong> @Model.Question.TeamName</p>
                        }
                        @if (!string.IsNullOrEmpty(Model.Question.CoreName))
                        {
                            <p><strong>Lớp:</strong> @Model.Question.CoreName</p>
                        }
                        @if (!string.IsNullOrEmpty(Model.Question.AssignedInstructorName))
                        {
                            <p><strong>GV phụ trách:</strong> @Model.Question.AssignedInstructorName</p>
                        }
                    </div>
                </div>

                <div class="card">
                    <div class="card-body">
                        <a asp-page="/Student/Questions/Index" class="btn btn-outline-secondary w-100">
                            <i class="bi bi-arrow-left"></i> Quay lại danh sách
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
