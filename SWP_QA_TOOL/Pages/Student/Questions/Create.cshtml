@page
@model SWP_QA_TOOL.Pages.Student.Questions.CreateModel
@{
    ViewData["Title"] = "Tạo câu hỏi mới";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-page="/Student/Index">Trang chủ</a></li>
                    <li class="breadcrumb-item"><a asp-page="/Student/Questions/Index">Câu hỏi</a></li>
                    <li class="breadcrumb-item active">Tạo câu hỏi</li>
                </ol>
            </nav>
            <h3><i class="bi bi-plus-square"></i> Tạo câu hỏi mới</h3>
            <p class="text-muted">Gửi câu hỏi cho giảng viên hướng dẫn</p>
        </div>
    </div>

    <div class="row">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0"><i class="bi bi-question-circle"></i> Nội dung câu hỏi</h5>
                </div>
                <div class="card-body">
                    <form method="post">
                        <div asp-validation-summary="All" class="text-danger"></div>

                        <div class="mb-3">
                            <label asp-for="Question.Title" class="form-label">Tiêu đề câu hỏi <span class="text-danger">*</span></label>
                            <input asp-for="Question.Title" class="form-control" placeholder="Nhập tiêu đề ngắn gọn cho câu hỏi..." required />
                            <span asp-validation-for="Question.Title" class="text-danger"></span>
                            <div class="form-text">Tiêu đề nên ngắn gọn, súc tích (tối đa 200 ký tự)</div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="Question.TeamId" class="form-label">Nhóm</label>
                                    <select asp-for="Question.TeamId" asp-items="Model.Teams" class="form-select">
                                        <option value="">-- Chọn nhóm --</option>
                                    </select>
                                    <span asp-validation-for="Question.TeamId" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="Question.CoreId" class="form-label">Lớp</label>
                                    <select asp-for="Question.CoreId" asp-items="Model.Cores" class="form-select">
                                        <option value="">-- Chọn lớp --</option>
                                    </select>
                                    <span asp-validation-for="Question.CoreId" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Question.Category" class="form-label">Phân loại câu hỏi</label>
                            <select asp-for="Question.Category" class="form-select">
                                <option value="">-- Chọn phân loại --</option>
                                <option value="Requirements">Yêu cầu (Requirements)</option>
                                <option value="Design">Thiết kế (Design)</option>
                                <option value="Database">Database</option>
                                <option value="Coding">Coding</option>
                                <option value="Testing">Testing</option>
                                <option value="Deployment">Deployment</option>
                                <option value="Other">Khác</option>
                            </select>
                            <span asp-validation-for="Question.Category" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Question.Body" class="form-label">Nội dung chi tiết <span class="text-danger">*</span></label>
                            <textarea asp-for="Question.Body" class="form-control" rows="10" placeholder="Mô tả chi tiết câu hỏi của bạn..." required></textarea>
                            <span asp-validation-for="Question.Body" class="text-danger"></span>
                            <div class="form-text">
                                <i class="bi bi-markdown"></i> Hỗ trợ định dạng Markdown
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Question.Difficulty" class="form-label">Mức độ khó</label>
                            <select asp-for="Question.Difficulty" class="form-select">
                                <option value="">-- Chọn mức độ --</option>
                                <option value="Easy">Dễ</option>
                                <option value="Medium">Trung bình</option>
                                <option value="Hard">Khó</option>
                            </select>
                            <span asp-validation-for="Question.Difficulty" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <div class="form-check">
                                <input asp-for="Question.IsPrivate" class="form-check-input" type="checkbox" />
                                <label asp-for="Question.IsPrivate" class="form-check-label">
                                    Câu hỏi riêng tư (chỉ GV và nhóm của bạn xem được)
                                </label>
                            </div>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-success">
                                <i class="bi bi-send"></i> Gửi câu hỏi
                            </button>
                            <a asp-page="/Student/Questions/Index" class="btn btn-outline-danger">
                                <i class="bi bi-x-circle"></i> Hủy
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card mb-3">
                <div class="card-header bg-light">
                    <h6 class="mb-0"><i class="bi bi-info-circle"></i> Hướng dẫn đặt câu hỏi</h6>
                </div>
                <div class="card-body">
                    <ol class="small">
                        <li class="mb-2">Đặt tiêu đề rõ ràng, ngắn gọn</li>
                        <li class="mb-2">Mô tả chi tiết vấn đề bạn gặp phải</li>
                        <li class="mb-2">Chọn nhóm và lớp liên quan</li>
                        <li class="mb-2">Chọn phân loại phù hợp</li>
                        <li class="mb-2">Kiểm tra lại trước khi gửi</li>
                    </ol>
                </div>
            </div>

            <div class="card">
                <div class="card-header bg-warning text-dark">
                    <h6 class="mb-0"><i class="bi bi-exclamation-triangle"></i> Lưu ý</h6>
                </div>
                <div class="card-body">
                    <ul class="small mb-0">
                        <li>Kiểm tra kỹ câu hỏi tương tự trước khi đặt câu hỏi mới</li>
                        <li>Câu hỏi sau khi gửi có thể chỉnh sửa cho đến khi được trả lời</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
