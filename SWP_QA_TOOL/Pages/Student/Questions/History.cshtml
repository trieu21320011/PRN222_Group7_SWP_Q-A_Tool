@page
@model SWP_QA_TOOL.Pages.Student.Questions.HistoryModel
@{
    ViewData["Title"] = "Lịch sử hỏi đáp";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-page="/Student/Index">Trang chủ</a></li>
                    <li class="breadcrumb-item"><a asp-page="/Student/Questions/Index">Câu hỏi</a></li>
                    <li class="breadcrumb-item active">Lịch sử</li>
                </ol>
            </nav>
            <h3><i class="bi bi-clock-history"></i> Lịch sử hỏi đáp</h3>
            <p class="text-muted">Các câu hỏi đã được giải quyết</p>
        </div>
    </div>

    <div class="alert alert-primary">
        <i class="bi bi-check-circle-fill"></i> Có <strong>@Model.Questions.Count()</strong> câu hỏi đã được giải quyết
    </div>

    <div class="row">
        <div class="col-12">
            @if (Model.Questions.Any())
            {
                @foreach (var question in Model.Questions.OrderByDescending(q => q.CreatedAt))
                {
                    <div class="card mb-3 border-primary">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <h5 class="card-title mb-1">
                                        <a asp-page="/Student/Questions/Details" asp-route-id="@question.QuestionId" class="text-decoration-none">
                                            @question.Title
                                        </a>
                                        <span class="badge bg-primary ms-2">Đã giải quyết</span>
                                    </h5>
                                    <p class="text-muted mb-2">
                                        <i class="bi bi-person"></i> Hỏi bởi: @question.AuthorName
                                        <small class="ms-2">| @question.CreatedAt?.ToString("dd/MM/yyyy HH:mm")</small>
                                        <small class="ms-2">| <i class="bi bi-chat-dots"></i> @question.AnswerCount câu trả lời</small>
                                    </p>
                                    <p class="card-text">
                                        @(question.Body?.Length > 150 ? question.Body.Substring(0, 150) + "..." : question.Body)
                                    </p>
                                    @if (!string.IsNullOrEmpty(question.TeamName))
                                    {
                                        <span class="badge bg-info me-1"><i class="bi bi-people"></i> @question.TeamName</span>
                                    }
                                    @if (!string.IsNullOrEmpty(question.CoreName))
                                    {
                                        <span class="badge bg-secondary"><i class="bi bi-building"></i> @question.CoreName</span>
                                    }
                                    @if (!string.IsNullOrEmpty(question.Category))
                                    {
                                        <span class="badge bg-light text-dark ms-1">@question.Category</span>
                                    }
                                </div>
                                <div>
                                    <a asp-page="/Student/Questions/Details" asp-route-id="@question.QuestionId" class="btn btn-outline-primary btn-sm">
                                        <i class="bi bi-eye"></i> Xem chi tiết
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="alert alert-info text-center">
                    <i class="bi bi-info-circle"></i> Chưa có câu hỏi nào được giải quyết
                </div>
            }
        </div>
    </div>

    <div class="text-center mt-4">
        <a asp-page="/Student/Questions/Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Quay lại danh sách
        </a>
    </div>
</div>
