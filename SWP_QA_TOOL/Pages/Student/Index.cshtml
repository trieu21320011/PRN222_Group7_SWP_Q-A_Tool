@page
@model SWP_QA_TOOL.Pages.Student.IndexModel
@{
    ViewData["Title"] = "Trang chủ Sinh viên";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <h2><i class="bi bi-house-door"></i> Xin chào, Sinh viên!</h2>
            <p class="text-muted">Tổng quan hoạt động và thông tin cá nhân</p>
        </div>
    </div>

    <!-- Thống kê nhanh -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card bg-primary text-white h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="card-title">Core của tôi</h6>
                            <h2 class="mb-0">1</h2>
                        </div>
                        <i class="bi bi-collection" style="font-size: 2.5rem; opacity: 0.5;"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-success text-white h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="card-title">Nhóm của tôi</h6>
                            <h2 class="mb-0">1</h2>
                        </div>
                        <i class="bi bi-people" style="font-size: 2.5rem; opacity: 0.5;"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-info text-white h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="card-title">Câu hỏi đã gửi</h6>
                            <h2 class="mb-0">5</h2>
                        </div>
                        <i class="bi bi-question-circle" style="font-size: 2.5rem; opacity: 0.5;"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-warning text-white h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="card-title">Chờ trả lời</h6>
                            <h2 class="mb-0">2</h2>
                        </div>
                        <i class="bi bi-hourglass-split" style="font-size: 2.5rem; opacity: 0.5;"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- Thông tin nhóm -->
        <div class="col-md-6 mb-4">
            <div class="card h-100">
                <div class="card-header bg-white">
                    <h5 class="mb-0"><i class="bi bi-people text-success"></i> Nhóm của tôi</h5>
                </div>
                <div class="card-body">
                    <h5>Nhóm 1 - SWP391</h5>
                    <p class="text-muted">Q&A Tool cho môn học</p>
                    <div class="mb-3">
                        <span class="badge bg-info">Core A</span>
                        <span class="badge bg-secondary">5 thành viên</span>
                    </div>
                    <p><strong>Tiến độ:</strong></p>
                    <div class="progress mb-3">
                        <div class="progress-bar bg-success" style="width: 85%">85%</div>
                    </div>
                    <p><strong>Thành viên:</strong></p>
                    <ul class="list-unstyled">
                        <li><i class="bi bi-person-fill"></i> Nguyễn Văn A (Nhóm trưởng)</li>
                        <li><i class="bi bi-person"></i> Trần Thị B</li>
                        <li><i class="bi bi-person"></i> Lê Văn C</li>
                        <li><i class="bi bi-person"></i> Phạm Thị D</li>
                        <li><i class="bi bi-person"></i> Hoàng Văn E</li>
                    </ul>
                </div>
                <div class="card-footer bg-white">
                    <a href="/Student/Teams/MyTeam" class="btn btn-sm btn-outline-success">
                        <i class="bi bi-eye"></i> Chi tiết nhóm
                    </a>
                    <a href="/Student/Teams/Edit" class="btn btn-sm btn-outline-primary">
                        <i class="bi bi-pencil"></i> Chỉnh sửa
                    </a>
                </div>
            </div>
        </div>

        <!-- Câu hỏi gần đây -->
        <div class="col-md-6 mb-4">
            <div class="card h-100">
                <div class="card-header bg-white">
                    <h5 class="mb-0"><i class="bi bi-chat-left-text text-primary"></i> Câu hỏi gần đây</h5>
                </div>
                <div class="card-body">
                    <ul class="list-group list-group-flush">
                        <li class="list-group-item d-flex justify-content-between align-items-start">
                            <div class="ms-2 me-auto">
                                <div class="fw-bold">Câu hỏi về Use Case Diagram</div>
                                <small class="text-muted">Gửi 10 phút trước</small>
                            </div>
                            <span class="badge bg-warning rounded-pill">Chờ trả lời</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-start">
                            <div class="ms-2 me-auto">
                                <div class="fw-bold">Hỏi về Database Design</div>
                                <small class="text-muted">Gửi 2 ngày trước</small>
                            </div>
                            <span class="badge bg-success rounded-pill">Đã trả lời</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-start">
                            <div class="ms-2 me-auto">
                                <div class="fw-bold">Xác nhận requirement</div>
                                <small class="text-muted">Gửi 1 tuần trước</small>
                            </div>
                            <span class="badge bg-primary rounded-pill">Đã giải quyết</span>
                        </li>
                    </ul>
                </div>
                <div class="card-footer bg-white">
                    <a href="/Student/Questions/Create" class="btn btn-sm btn-success">
                        <i class="bi bi-plus-circle"></i> Tạo câu hỏi mới
                    </a>
                    <a href="/Student/Questions/Index" class="btn btn-sm btn-outline-primary">
                        Xem tất cả <i class="bi bi-arrow-right"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Thông báo mới -->
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header bg-white">
                    <h5 class="mb-0"><i class="bi bi-bell text-warning"></i> Thông báo mới</h5>
                </div>
                <div class="card-body">
                    <div class="alert alert-success mb-2">
                        <i class="bi bi-check-circle"></i>
                        <strong>Câu hỏi đã được trả lời:</strong> "Hỏi về Database Design" - Xem ngay
                        <small class="text-muted float-end">2 ngày trước</small>
                    </div>
                    <div class="alert alert-info mb-2">
                        <i class="bi bi-info-circle"></i>
                        <strong>Thông báo từ GV:</strong> Deadline nộp báo cáo tiến độ cuối tuần này
                        <small class="text-muted float-end">3 ngày trước</small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
