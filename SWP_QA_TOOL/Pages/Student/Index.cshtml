@page
@model SWP_QA_TOOL.Pages.Student.IndexModel
@{
    ViewData["Title"] = "Trang chủ Sinh viên";
    var userName = User.FindFirst("DisplayName")?.Value ?? User.Identity?.Name ?? "Sinh viên";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <h2><i class="bi bi-house-door"></i> Xin chào, @userName!</h2>
            <p class="text-muted">Tổng quan hoạt động và thông tin cá nhân</p>
        </div>
    </div>

    <!-- Thống kê nhanh -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card bg-primary text-white h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="card-title">Lớp của tôi</h6>
                            <h2 class="mb-0">@Model.MyCores.Count</h2>
                        </div>
                        <i class="bi bi-collection" style="font-size: 2.5rem; opacity: 0.5;"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-success text-white h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="card-title">Nhóm của tôi</h6>
                            <h2 class="mb-0">@Model.MyTeams.Count</h2>
                        </div>
                        <i class="bi bi-people" style="font-size: 2.5rem; opacity: 0.5;"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-info text-white h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="card-title">Câu hỏi đã gửi</h6>
                            <h2 class="mb-0">@Model.MyQuestions.Count</h2>
                        </div>
                        <i class="bi bi-question-circle" style="font-size: 2.5rem; opacity: 0.5;"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-warning text-white h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="card-title">Chờ trả lời</h6>
                            <h2 class="mb-0">@Model.PendingQuestions.Count</h2>
                        </div>
                        <i class="bi bi-hourglass-split" style="font-size: 2.5rem; opacity: 0.5;"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- Thông tin nhóm -->
        <div class="col-md-6 mb-4">
            <div class="card h-100">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0"><i class="bi bi-people text-success"></i> Nhóm của tôi</h5>
                    @if (!Model.MyTeams.Any())
                    {
                        <a asp-page="/Student/Teams/Create" class="btn btn-sm btn-success">
                            <i class="bi bi-plus-circle"></i> Tạo nhóm
                        </a>
                    }
                </div>
                <div class="card-body">
                    @if (Model.MyTeams.Any())
                    {
                        @foreach (var team in Model.MyTeams.Take(1))
                        {
                            <h5>@team.TeamName</h5>
                            <p class="text-muted">@team.ProjectName</p>
                            <div class="mb-3">
                                @if (!string.IsNullOrEmpty(team.CoreName))
                                {
                                    <span class="badge bg-info">@team.CoreName</span>
                                }
                                @if (!string.IsNullOrEmpty(team.TopicName))
                                {
                                    <span class="badge bg-secondary">@team.TopicName</span>
                                }
                            </div>
                            <p><strong><i class="bi bi-person-badge"></i> Nhóm trưởng:</strong> @(team.LeaderName ?? "Chưa có")</p>
                            <p><strong><i class="bi bi-person-workspace"></i> GV hướng dẫn:</strong> @(team.MentorName ?? "Chưa có")</p>
                        }
                    }
                    else
                    {
                        <div class="text-center text-muted py-4">
                            <i class="bi bi-people" style="font-size: 3rem;"></i>
                            <p class="mt-2">Bạn chưa tham gia nhóm nào</p>
                            <a asp-page="/Student/Teams/Create" class="btn btn-success">
                                <i class="bi bi-plus-circle"></i> Tạo nhóm mới
                            </a>
                        </div>
                    }
                </div>
                @if (Model.MyTeams.Any())
                {
                    <div class="card-footer bg-white">
                        <a asp-page="/Student/Teams/MyTeam" class="btn btn-sm btn-outline-success">
                            <i class="bi bi-eye"></i> Chi tiết nhóm
                        </a>
                        <a asp-page="/Student/Teams/Edit" class="btn btn-sm btn-outline-primary">
                            <i class="bi bi-pencil"></i> Chỉnh sửa
                        </a>
                        <a asp-page="/Student/Teams/Members" class="btn btn-sm btn-outline-info">
                            <i class="bi bi-person-plus"></i> Thành viên
                        </a>
                    </div>
                }
            </div>
        </div>

        <!-- Câu hỏi gần đây -->
        <div class="col-md-6 mb-4">
            <div class="card h-100">
                <div class="card-header bg-white">
                    <h5 class="mb-0"><i class="bi bi-chat-left-text text-primary"></i> Câu hỏi gần đây</h5>
                </div>
                <div class="card-body">
                    @if (Model.MyQuestions.Any())
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var question in Model.MyQuestions.OrderByDescending(q => q.CreatedAt).Take(5))
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-start">
                                    <div class="ms-2 me-auto">
                                        <div class="fw-bold">
                                            <a asp-page="/Student/Questions/Details" asp-route-id="@question.QuestionId" class="text-decoration-none">
                                                @question.Title
                                            </a>
                                        </div>
                                        <small class="text-muted">
                                            @if (question.CreatedAt.HasValue)
                                            {
                                                var timeAgo = DateTime.Now - question.CreatedAt.Value;
                                                @if (timeAgo.TotalMinutes < 60)
                                                {
                                                    <text>@((int)timeAgo.TotalMinutes) phút trước</text>
                                                }
                                                else if (timeAgo.TotalHours < 24)
                                                {
                                                    <text>@((int)timeAgo.TotalHours) giờ trước</text>
                                                }
                                                else
                                                {
                                                    <text>@((int)timeAgo.TotalDays) ngày trước</text>
                                                }
                                            }
                                        </small>
                                    </div>
                                    @if (question.IsClosed == true)
                                    {
                                        <span class="badge bg-primary rounded-pill">Đã giải quyết</span>
                                    }
                                    else if (question.AnswerCount > 0)
                                    {
                                        <span class="badge bg-success rounded-pill">Đã trả lời (@question.AnswerCount)</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning rounded-pill">Chờ trả lời</span>
                                    }
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <div class="text-center text-muted py-4">
                            <i class="bi bi-chat-left-text" style="font-size: 3rem;"></i>
                            <p class="mt-2">Bạn chưa có câu hỏi nào</p>
                        </div>
                    }
                </div>
                <div class="card-footer bg-white">
                    <a asp-page="/Student/Questions/Create" class="btn btn-sm btn-success">
                        <i class="bi bi-plus-circle"></i> Tạo câu hỏi mới
                    </a>
                    <a asp-page="/Student/Questions/Index" class="btn btn-sm btn-outline-primary">
                        Xem tất cả <i class="bi bi-arrow-right"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Lớp của tôi -->
    <div class="row">
        <div class="col-12 mb-4">
            <div class="card">
                <div class="card-header bg-white">
                    <h5 class="mb-0"><i class="bi bi-collection text-primary"></i> Lớp của tôi</h5>
                </div>
                <div class="card-body">
                    @if (Model.MyCores.Any())
                    {
                        <div class="row">
                            @foreach (var core in Model.MyCores)
                            {
                                <div class="col-md-4 mb-3">
                                    <div class="card border-primary">
                                        <div class="card-header bg-primary text-white">
                                            <h6 class="mb-0">@core.CoreCode - @core.CoreName</h6>
                                        </div>
                                        <div class="card-body">
                                            <p><i class="bi bi-person-badge"></i> <strong>GV:</strong> @core.InstructorName</p>
                                            <p><i class="bi bi-calendar"></i> <strong>Học kỳ:</strong> @core.SemesterCode</p>
                                            <p><i class="bi bi-clock"></i> <strong>Lịch:</strong> @core.Schedule</p>
                                            <p><i class="bi bi-geo-alt"></i> <strong>Phòng:</strong> @core.Room</p>
                                        </div>
                                        <div class="card-footer bg-white">
                                            <a asp-page="/Student/Cores/Index" class="btn btn-sm btn-outline-primary">
                                                <i class="bi bi-eye"></i> Chi tiết
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-center text-muted py-4">
                            <i class="bi bi-collection" style="font-size: 3rem;"></i>
                            <p class="mt-2">Bạn chưa được phân vào lớp nào</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
