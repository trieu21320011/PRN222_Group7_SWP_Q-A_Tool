@page "{id:int}"
@model SWP_QA_TOOL.Pages.Student.Teams.EditModel
@{
    ViewData["Title"] = "Chỉnh sửa nhóm";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-page="/Student/Index">Trang chủ</a></li>
                    <li class="breadcrumb-item"><a asp-page="/Student/Teams/MyTeam">Nhóm của tôi</a></li>
                    <li class="breadcrumb-item active">Chỉnh sửa</li>
                </ol>
            </nav>
            <h3><i class="bi bi-pencil"></i> Chỉnh sửa nhóm</h3>
            <p class="text-muted">Cập nhật thông tin nhóm của bạn</p>
        </div>
    </div>

    @if (TempData["ErrorMessage"] is string errorMessage)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @errorMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="bi bi-people-fill"></i> Thông tin nhóm</h5>
                </div>
                <div class="card-body">
                    <form method="post">
                        <div asp-validation-summary="All" class="text-danger"></div>
                        <input type="hidden" asp-for="Team.TeamId" />
                        <input type="hidden" asp-for="Team.TeamCode" />

                        <div class="mb-3">
                            <label asp-for="Team.TeamName" class="form-label">Tên nhóm <span class="text-danger">*</span></label>
                            <input asp-for="Team.TeamName" class="form-control" required />
                            <span asp-validation-for="Team.TeamName" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Lớp</label>
                            <input type="text" class="form-control" value="@Model.CoreName" disabled />
                            <div class="form-text text-warning">
                                <i class="bi bi-exclamation-triangle"></i> Không thể thay đổi Lớp sau khi đã tạo nhóm
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Team.TopicId" class="form-label">Đề tài</label>
                            <select asp-for="Team.TopicId" asp-items="Model.Topics" class="form-select">
                                <option value="">-- Chọn đề tài --</option>
                            </select>
                            <span asp-validation-for="Team.TopicId" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Team.ProjectName" class="form-label">Tên dự án</label>
                            <input asp-for="Team.ProjectName" class="form-control" placeholder="Nhập tên dự án..." />
                            <span asp-validation-for="Team.ProjectName" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Team.Description" class="form-label">Mô tả</label>
                            <textarea asp-for="Team.Description" class="form-control" rows="4"></textarea>
                            <span asp-validation-for="Team.Description" class="text-danger"></span>
                        </div>

                        <div class="d-flex gap-2 mt-4">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-check-circle"></i> Lưu thay đổi
                            </button>
                            <a asp-page="/Student/Teams/MyTeam" class="btn btn-outline-secondary">
                                <i class="bi bi-x-circle"></i> Hủy
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card mb-3">
                <div class="card-header bg-light">
                    <h6 class="mb-0"><i class="bi bi-people"></i> Quản lý thành viên</h6>
                </div>
                <div class="card-body">
                    <p class="small text-muted">Quản lý thành viên trong nhóm, thêm hoặc xóa thành viên.</p>
                    <a asp-page="/Student/Teams/Members" asp-route-id="@Model.Team.TeamId" class="btn btn-outline-primary w-100">
                        <i class="bi bi-person-plus"></i> Quản lý thành viên
                    </a>
                </div>
            </div>

            <div class="card">
                <div class="card-header bg-light">
                    <h6 class="mb-0"><i class="bi bi-info-circle"></i> Thông tin</h6>
                </div>
                <div class="card-body">
                    <p class="small text-muted mb-1"><strong>Mã nhóm:</strong> @Model.Team.TeamCode</p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
