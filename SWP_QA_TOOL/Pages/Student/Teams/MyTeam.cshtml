@page
@model SWP_QA_TOOL.Pages.Student.Teams.MyTeamModel
@{
    ViewData["Title"] = "Nhóm của tôi";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <h3><i class="bi bi-people"></i> Nhóm của tôi</h3>
            <p class="text-muted">Thông tin chi tiết về nhóm của bạn</p>
        </div>
    </div>

    @if (Model.MyTeam == null)
    {
        <div class="row">
            <div class="col-12">
                <div class="alert alert-info">
                    <i class="bi bi-info-circle"></i> Bạn chưa tham gia nhóm nào.
                    <a asp-page="/Student/Teams/Create" class="alert-link">Tạo nhóm mới</a> để bắt đầu.
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="row">
            <div class="col-md-8">
                <div class="card mb-4">
                    <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
                        <h5 class="mb-0"><i class="bi bi-people-fill"></i> @Model.MyTeam.TeamName</h5>
                        @if (Model.IsLeader)
                        {
                            <a asp-page="/Student/Teams/Edit" asp-route-id="@Model.MyTeam.TeamId" class="btn btn-sm btn-light">
                                <i class="bi bi-pencil"></i> Chỉnh sửa
                            </a>
                        }
                    </div>
                    <div class="card-body">
                        <div class="row mb-4">
                            <div class="col-md-6">
                                <p><strong><i class="bi bi-collection"></i> Lớp:</strong> @(Model.MyTeam.CoreName ?? "Chưa xác định")</p>
                                <p><strong><i class="bi bi-journal-bookmark"></i> Đề tài:</strong> @(Model.MyTeam.TopicName ?? "Chưa xác định")</p>
                            </div>
                            <div class="col-md-6">
                                <p><strong><i class="bi bi-people"></i> Số thành viên:</strong> @Model.TeamMembers.Count</p>
                                <p><strong><i class="bi bi-flag"></i> Trạng thái:</strong> 
                                    <span class="badge bg-success">Hoạt động</span>
                                </p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Danh sách thành viên -->
                <div class="card">
                    <div class="card-header bg-white d-flex justify-content-between align-items-center">
                        <h6 class="mb-0"><i class="bi bi-person-lines-fill"></i> Thành viên nhóm (@Model.TeamMembers.Count)</h6>
                        @if (Model.IsLeader)
                        {
                            <a asp-page="/Student/Teams/Members" asp-route-id="@Model.MyTeam.TeamId" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-person-plus"></i> Quản lý thành viên
                            </a>
                        }
                    </div>
                    <div class="card-body">
                        @if (Model.TeamMembers.Any())
                        {
                            <table class="table table-hover">
                                <thead class="table-light">
                                    <tr>
                                        <th>#</th>
                                        <th>Họ tên</th>
                                        <th>Email</th>
                                        <th>Vai trò</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @{
                                        var index = 1;
                                    }
                                    @foreach (var member in Model.TeamMembers)
                                    {
                                        var isLeader = member.Role == "Leader";
                                        <tr class="@(isLeader ? "table-success" : "")">
                                            <td>@(index++)</td>
                                        <td>@(member.FullName ?? member.UserName)</td>
                                            <td>@member.Email</td>
                                            <td>
                                                @if (isLeader)
                                                {
                                                    <span class="badge bg-primary">Nhóm trưởng</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary">Thành viên</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                        else
                        {
                            <p class="text-muted">Chưa có thành viên trong nhóm.</p>
                        }
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card mb-3">
                    <div class="card-header bg-light">
                        <h6 class="mb-0"><i class="bi bi-lightning"></i> Hành động</h6>
                    </div>
                    <div class="card-body">
                        <div class="d-grid gap-2">
                            <a asp-page="/Student/Questions/Create" class="btn btn-success">
                                <i class="bi bi-plus-circle"></i> Tạo câu hỏi mới
                            </a>
                            <a asp-page="/Student/Questions/Index" class="btn btn-outline-primary">
                                <i class="bi bi-question-circle"></i> Xem câu hỏi nhóm
                            </a>
                            @if (Model.IsLeader)
                            {
                                <a asp-page="/Student/Teams/Edit" asp-route-id="@Model.MyTeam.TeamId" class="btn btn-outline-secondary">
                                    <i class="bi bi-pencil"></i> Chỉnh sửa nhóm
                                </a>
                            }
                        </div>
                    </div>
                </div>

                <div class="card">
                    <div class="card-header bg-light">
                        <h6 class="mb-0"><i class="bi bi-info-circle"></i> Thông tin nhóm</h6>
                    </div>
                    <div class="card-body">
                        <div class="d-flex justify-content-between mb-2">
                            <span>Mã nhóm:</span>
                            <span class="badge bg-secondary">@Model.MyTeam.TeamId</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span>Số thành viên:</span>
                            <span class="badge bg-info">@Model.TeamMembers.Count</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
