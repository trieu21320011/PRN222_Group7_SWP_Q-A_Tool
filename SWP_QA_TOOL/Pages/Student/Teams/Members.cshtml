@page "{id:int}"
@model SWP_QA_TOOL.Pages.Student.Teams.MembersModel
@{
    ViewData["Title"] = "Quản lý thành viên";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-page="/Student/Index">Trang chủ</a></li>
                    <li class="breadcrumb-item"><a asp-page="/Student/Teams/MyTeam">Nhóm của tôi</a></li>
                    <li class="breadcrumb-item active">Quản lý thành viên</li>
                </ol>
            </nav>
            <h3><i class="bi bi-person-plus"></i> Quản lý thành viên</h3>
            <p class="text-muted">Thêm, xóa thành viên trong nhóm</p>
        </div>
    </div>

    @if (TempData["SuccessMessage"] is string successMessage)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @successMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] is string errorMessage)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @errorMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row">
        <div class="col-md-8">
            <!-- Danh sách thành viên hiện tại -->
            <div class="card mb-4">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0"><i class="bi bi-people-fill"></i> Thành viên hiện tại (@Model.TeamMembers.Count)</h5>
                </div>
                <div class="card-body">
                    @if (Model.TeamMembers.Any())
                    {
                        <table class="table table-hover">
                            <thead class="table-light">
                                <tr>
                                    <th>#</th>
                                    <th>Họ tên</th>
                                    <th>Email</th>
                                    <th>Vai trò</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @{
                                    var index = 1;
                                }
                                @foreach (var member in Model.TeamMembers)
                                {
                                    var isLeader = member.Role == "Leader";
                                    <tr class="@(isLeader ? "table-success" : "")">
                                        <td>@(index++)</td>
                                        <td>
                                            @if (isLeader)
                                            {
                                                <i class="bi bi-star-fill text-warning"></i>
                                            }
                                            @(member.FullName ?? member.UserName)
                                        </td>
                                        <td>@member.Email</td>
                                        <td>
                                            @if (isLeader)
                                            {
                                                <span class="badge bg-primary">Nhóm trưởng</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">Thành viên</span>
                                            }
                                        </td>
                                        <td>
                                            @if (!isLeader && Model.IsLeader)
                                            {
                                                <form method="post" asp-page-handler="RemoveMember" asp-route-id="@Model.Team?.TeamId" asp-route-userId="@member.UserId" style="display: inline;">
                                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Xóa thành viên" onclick="return confirm('Bạn có chắc muốn xóa thành viên này?');">
                                                        <i class="bi bi-person-x"></i>
                                                    </button>
                                                </form>
                                            }
                                            else if (isLeader)
                                            {
                                                <span>-</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <p class="text-muted">Chưa có thành viên nào trong nhóm.</p>
                    }
                </div>
            </div>

            <!-- Thêm thành viên mới -->
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="bi bi-person-plus-fill"></i> Thêm thành viên mới</h5>
                </div>
                <div class="card-body">
                    <form method="post" asp-page-handler="Search" asp-route-id="@Model.Team?.TeamId">
                        <div class="row">
                            <div class="col-md-8">
                                <div class="mb-3">
                                    <label class="form-label">Tìm sinh viên</label>
                                    <input asp-for="SearchEmail" type="text" class="form-control" placeholder="Nhập email sinh viên...">
                                    <div class="form-text">Ví dụ: example@fpt.edu.vn</div>
                                </div>
                            </div>
                            <div class="col-md-4 d-flex align-items-end">
                                <button type="submit" class="btn btn-outline-primary mb-3 w-100">
                                    <i class="bi bi-search"></i> Tìm kiếm
                                </button>
                            </div>
                        </div>
                    </form>

                    @if (Model.SearchResults != null && Model.SearchResults.Any())
                    {
                        <h6 class="mt-3">Kết quả tìm kiếm:</h6>
                        @foreach (var user in Model.SearchResults)
                        {
                            <div class="alert alert-secondary">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <strong>@(user.FullName ?? user.DisplayName)</strong><br>
                                        <small>@user.Email</small>
                                    </div>
                                    <form method="post" asp-page-handler="AddMember" asp-route-id="@Model.Team?.TeamId" asp-route-userId="@user.UserId">
                                        <button type="submit" class="btn btn-success">
                                            <i class="bi bi-person-plus"></i> Thêm vào nhóm
                                        </button>
                                    </form>
                                </div>
                            </div>
                        }
                    }
                    else if (Model.SearchResults != null && !Model.SearchResults.Any() && !string.IsNullOrEmpty(Model.SearchEmail))
                    {
                        <div class="alert alert-warning">
                            <i class="bi bi-exclamation-triangle"></i> Không tìm thấy sinh viên phù hợp.
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card mb-3">
                <div class="card-header bg-light">
                    <h6 class="mb-0"><i class="bi bi-info-circle"></i> Thông tin nhóm</h6>
                </div>
                <div class="card-body">
                    <p><strong>Tên nhóm:</strong> @Model.Team?.TeamName</p>
                    <p><strong>Lớp:</strong> @(Model.Team?.CoreName ?? "Chưa xác định")</p>
                    <p><strong>Số thành viên:</strong> @Model.TeamMembers.Count</p>
                </div>
            </div>

            <div class="card mb-3">
                <div class="card-header bg-warning text-dark">
                    <h6 class="mb-0"><i class="bi bi-exclamation-triangle"></i> Lưu ý</h6>
                </div>
                <div class="card-body">
                    <ul class="small mb-0">
                        <li>Chỉ nhóm trưởng mới có quyền quản lý thành viên</li>
                        <li>Thành viên bị xóa sẽ mất quyền truy cập nhóm</li>
                    </ul>
                </div>
            </div>

            <div class="card">
                <div class="card-body">
                    <a asp-page="/Student/Teams/MyTeam" class="btn btn-outline-secondary w-100">
                        <i class="bi bi-arrow-left"></i> Quay lại nhóm
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
