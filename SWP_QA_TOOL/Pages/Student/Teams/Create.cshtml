@page
@model SWP_QA_TOOL.Pages.Student.Teams.CreateModel
@{
    ViewData["Title"] = "Tạo nhóm mới";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-page="/Student/Index">Trang chủ</a></li>
                    <li class="breadcrumb-item active">Tạo nhóm mới</li>
                </ol>
            </nav>
            <h3><i class="bi bi-plus-circle"></i> Tạo nhóm mới</h3>
            <p class="text-muted">Tạo nhóm và đăng ký vào Lớp</p>
        </div>
    </div>

    @if (TempData["SuccessMessage"] is string successMessage)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @successMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0"><i class="bi bi-people-fill"></i> Thông tin nhóm</h5>
                </div>
                <div class="card-body">
                    <form method="post">
                        <div asp-validation-summary="All" class="text-danger"></div>
                        
                        <div class="mb-3">
                            <label asp-for="Team.TeamName" class="form-label">Tên nhóm <span class="text-danger">*</span></label>
                            <input asp-for="Team.TeamName" class="form-control" placeholder="Nhập tên nhóm..." required />
                            <span asp-validation-for="Team.TeamName" class="text-danger"></span>
                            <div class="form-text">Ví dụ: Nhóm 1, Team Alpha, v.v.</div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Team.CoreId" class="form-label">Chọn Lớp <span class="text-danger">*</span></label>
                            <select asp-for="Team.CoreId" asp-items="Model.Cores" class="form-select" required>
                                <option value="">-- Chọn Lớp --</option>
                            </select>
                            <span asp-validation-for="Team.CoreId" class="text-danger"></span>
                            <div class="form-text">Chọn Lớp bạn muốn đăng ký vào</div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Team.TopicId" class="form-label">Chọn đề tài</label>
                            <select asp-for="Team.TopicId" asp-items="Model.Topics" class="form-select">
                                <option value="">-- Chọn đề tài --</option>
                            </select>
                            <span asp-validation-for="Team.TopicId" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Team.ProjectName" class="form-label">Tên dự án</label>
                            <input asp-for="Team.ProjectName" class="form-control" placeholder="Nhập tên dự án..." />
                            <span asp-validation-for="Team.ProjectName" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Team.Description" class="form-label">Mô tả</label>
                            <textarea asp-for="Team.Description" class="form-control" rows="4" placeholder="Mô tả ngắn gọn về nhóm/dự án của bạn..."></textarea>
                            <span asp-validation-for="Team.Description" class="text-danger"></span>
                        </div>

                        <hr>

                        <div class="alert alert-info">
                            <i class="bi bi-info-circle"></i> Bạn sẽ tự động trở thành nhóm trưởng. Có thể thêm thành viên sau khi tạo nhóm.
                        </div>

                        <div class="d-flex gap-2 mt-4">
                            <button type="submit" class="btn btn-success">
                                <i class="bi bi-check-circle"></i> Tạo nhóm
                            </button>
                            <a asp-page="/Student/Index" class="btn btn-outline-secondary">
                                <i class="bi bi-x-circle"></i> Hủy
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card">
                <div class="card-header bg-light">
                    <h6 class="mb-0"><i class="bi bi-info-circle"></i> Hướng dẫn</h6>
                </div>
                <div class="card-body">
                    <ol class="small">
                        <li class="mb-2">Đặt tên nhóm dễ nhớ và ngắn gọn</li>
                        <li class="mb-2">Chọn Lớp phù hợp với lịch học của bạn</li>
                        <li class="mb-2">Mô tả đề tài để GV nắm được hướng đi của nhóm</li>
                        <li class="mb-2">Có thể thêm thành viên sau khi tạo nhóm</li>
                        <li class="mb-2">Số thành viên tối đa: 5-6 người</li>
                    </ol>
                </div>
            </div>

            <div class="card mt-3">
                <div class="card-header bg-warning text-dark">
                    <h6 class="mb-0"><i class="bi bi-exclamation-triangle"></i> Lưu ý</h6>
                </div>
                <div class="card-body">
                    <ul class="small mb-0">
                        <li>Mỗi sinh viên chỉ được tham gia 1 nhóm trong 1 Lớp</li>
                        <li>Không thể thay đổi Lớp sau khi đã tạo nhóm</li>
                        <li>Nhóm trưởng có thể mời/xóa thành viên</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
