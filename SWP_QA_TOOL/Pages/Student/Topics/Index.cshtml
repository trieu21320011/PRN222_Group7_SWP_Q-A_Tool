@page
@model SWP_QA_TOOL.Pages.Student.Topics.IndexModel
@{
    ViewData["Title"] = "Đề tài đăng ký";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-page="/Student/Index">Trang chủ</a></li>
                    <li class="breadcrumb-item active">Đề tài đăng ký</li>
                </ol>
            </nav>
            <h3><i class="bi bi-journal-bookmark"></i> Đề tài đăng ký</h3>
            <p class="text-muted">Xem thông tin đề tài mà nhóm bạn đã đăng ký</p>
        </div>
    </div>

    <div class="alert alert-info">
        <i class="bi bi-info-circle"></i> Bạn đang tham gia <strong>@Model.MyTeams.Count()</strong> nhóm với đề tài đăng ký
    </div>

    <div class="row">
        @if (Model.MyTeams.Any())
        {
            @foreach (var team in Model.MyTeams.Where(t => !string.IsNullOrEmpty(t.TopicName)))
            {
                <div class="col-md-6 mb-4">
                    <div class="card h-100">
                        <div class="card-header bg-primary text-white">
                            <h5 class="mb-0"><i class="bi bi-journal-bookmark-fill"></i> @team.TopicName</h5>
                        </div>
                        <div class="card-body">
                            <div class="row">
                                <div class="col-md-6">
                                    <p><strong><i class="bi bi-people"></i> Nhóm:</strong></p>
                                    <p class="ms-3">@team.TeamName (@team.TeamCode)</p>
                                    
                                    <p><strong><i class="bi bi-collection"></i> Lớp:</strong></p>
                                    <p class="ms-3">@(team.CoreName ?? "Chưa xác định")</p>
                                </div>
                                <div class="col-md-6">
                                    <p><strong><i class="bi bi-calendar"></i> Học kỳ:</strong></p>
                                    <p class="ms-3">@(team.SemesterCode ?? team.Semester ?? "N/A")</p>
                                    
                                    <p><strong><i class="bi bi-person-badge"></i> Mentor:</strong></p>
                                    <p class="ms-3">@(team.MentorName ?? "Chưa xác định")</p>
                                </div>
                            </div>
                            @if (!string.IsNullOrEmpty(team.ProjectName))
                            {
                                <hr>
                                <p><strong><i class="bi bi-briefcase"></i> Dự án:</strong></p>
                                <p class="ms-3">@team.ProjectName</p>
                            }
                            @if (!string.IsNullOrEmpty(team.Description))
                            {
                                <hr>
                                <p><strong><i class="bi bi-file-text"></i> Mô tả:</strong></p>
                                <p class="ms-3 text-muted">@team.Description</p>
                            }
                        </div>
                        <div class="card-footer bg-light">
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="badge @(team.IsActive == true ? "bg-success" : "bg-secondary")">
                                    @(team.IsActive == true ? "Đang hoạt động" : "Đã kết thúc")
                                </span>
                                <div>
                                    <a asp-page="/Student/Teams/MyTeam" class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-people"></i> Xem nhóm
                                    </a>
                                    <a asp-page="/Student/Questions/Create" class="btn btn-sm btn-success">
                                        <i class="bi bi-question-circle"></i> Đặt câu hỏi
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
            
            @if (!Model.MyTeams.Any(t => !string.IsNullOrEmpty(t.TopicName)))
            {
                <div class="col-12">
                    <div class="alert alert-warning text-center">
                        <i class="bi bi-exclamation-triangle"></i> Nhóm của bạn chưa đăng ký đề tài nào.
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <div class="alert alert-warning text-center">
                    <i class="bi bi-exclamation-triangle"></i> Bạn chưa tham gia nhóm nào.
                    <br>
                    <a asp-page="/Student/Teams/Create" class="btn btn-success mt-3">
                        <i class="bi bi-plus-circle"></i> Tạo nhóm mới
                    </a>
                </div>
            </div>
        }
    </div>
</div>
