@page
@model SWP_QA_TOOL.Pages.Instructor.Cores.IndexModel
@{
    ViewData["Title"] = "Lớp được phân công";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <h3><i class="bi bi-collection"></i> Lớp được phân công</h3>
            <p class="text-muted">Danh sách các lớp bạn được phân công quản lý</p>
        </div>
    </div>

    <form method="get" class="row mb-3">
        <div class="col-md-4">
            <div class="input-group">
                <input type="text" name="search" class="form-control" placeholder="Tìm kiếm lớp..." value="@Model.SearchTerm">
                <button class="btn btn-outline-primary" type="submit">
                    <i class="bi bi-search"></i>
                </button>
            </div>
        </div>
    </form>

    <div class="card">
        <div class="card-body">
            @if (Model.Cores.Any())
            {
                <table class="table table-hover">
                    <thead class="table-light">
                        <tr>
                            <th>#</th>
                            <th>Tên Lớp</th>
                            <th>Lịch học</th>
                            <th>Học kỳ</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ var index = 0; }
                        @foreach (var core in Model.Cores)
                        {
                            index++;
                            <tr>
                                <td>@index</td>
                                <td><strong>@core.CoreName</strong></td>
                                <td>@(core.Schedule ?? "Chưa xác định")</td>
                                <td><span class="badge bg-info">@(core.SemesterCode ?? "Chưa xác định")</span></td>
                                <td>
                                    <a asp-page="Details" asp-route-id="@core.CoreId" class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-eye"></i> Chi tiết
                                    </a>
                                    <a asp-page="/Instructor/Teams/Index" asp-route-coreId="@core.CoreId" class="btn btn-sm btn-outline-success">
                                        <i class="bi bi-people"></i> Nhóm
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="bi bi-folder2-open" style="font-size: 3rem; color: #6c757d;"></i>
                    <p class="text-muted mt-3">Không có lớp nào được phân công</p>
                </div>
            }
        </div>
    </div>
</div>
