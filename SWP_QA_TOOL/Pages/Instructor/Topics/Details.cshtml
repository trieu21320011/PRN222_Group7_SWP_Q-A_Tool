@page "{id:int}"
@model SWP_QA_TOOL.Pages.Instructor.Topics.DetailsModel
@{
    ViewData["Title"] = "Chi tiết Đề tài";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-page="/Instructor/Index">Trang chủ</a></li>
                    <li class="breadcrumb-item"><a asp-page="Index">Đề tài</a></li>
                    <li class="breadcrumb-item active">Chi tiết</li>
                </ol>
            </nav>
        </div>
    </div>

    @if (Model.Topic != null)
    {
        <div class="row mb-4">
            <div class="col-md-8">
                <div class="card">
                    <div class="card-header bg-success text-white">
                        <h4 class="mb-0">
                            <i class="bi bi-journal-bookmark"></i> @Model.Topic.TopicName
                        </h4>
                    </div>
                    <div class="card-body">
                        <p><strong>Mô tả:</strong></p>
                        <p>@(Model.Topic.Description ?? "Không có mô tả")</p>
                        <hr />
                        <p>
                            <strong>Học kỳ:</strong> 
                            <span class="badge bg-info">@(Model.Topic.SemesterCode ?? "Chưa xác định")</span>
                        </p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card bg-light">
                    <div class="card-body text-center">
                        <h5>Số Lớp</h5>
                        <h2 class="text-success">@Model.Cores.Count()</h2>
                        <small class="text-muted">trong đề tài này</small>
                    </div>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-header bg-white">
                <h5 class="mb-0"><i class="bi bi-folder2"></i> Danh sách Lớp</h5>
            </div>
            <div class="card-body">
                @if (Model.Cores.Any())
                {
                    <div class="row">
                        @foreach (var core in Model.Cores)
                        {
                            <div class="col-md-4 mb-3">
                                <div class="card h-100">
                                    <div class="card-body">
                                        <h6 class="card-title">@core.CoreName</h6>
                                        <p class="card-text small text-muted">
                                            @(core.Schedule ?? "Chưa xác định")
                                        </p>
                                        @if (core.InstructorName != null)
                                        {
                                            <p class="mb-0"><small><i class="bi bi-person"></i> @core.InstructorName</small></p>
                                        }
                                    </div>
                                    <div class="card-footer bg-white">
                                        <a asp-page="/Instructor/Cores/Details" asp-route-id="@core.CoreId" class="btn btn-sm btn-outline-primary">
                                            <i class="bi bi-eye"></i> Xem chi tiết
                                        </a>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center py-4 text-muted">
                        <i class="bi bi-folder2-open" style="font-size: 2rem;"></i>
                        <p class="mt-2">Chưa có lớp nào trong đề tài này</p>
                    </div>
                }
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-warning">
            <i class="bi bi-exclamation-triangle"></i> Không tìm thấy đề tài
        </div>
    }

    <div class="mt-4">
        <a asp-page="Index" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Quay lại
        </a>
    </div>
</div>
