@page
@model SWP_QA_TOOL.Pages.Instructor.Semesters.IndexModel
@{
    ViewData["Title"] = "Học kỳ hoạt động";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <h3><i class="bi bi-calendar-check"></i> Học kỳ hoạt động</h3>
            <p class="text-muted">Xem thông tin các học kỳ đang hoạt động mà bạn tham gia</p>
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            @if (Model.Semesters.Any())
            {
                <table class="table table-hover">
                    <thead class="table-light">
                        <tr>
                            <th>#</th>
                            <th>Tên học kỳ</th>
                            <th>Ngày bắt đầu</th>
                            <th>Ngày kết thúc</th>
                            <th>Trạng thái</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ var index = 0; }
                        @foreach (var semester in Model.Semesters)
                        {
                            index++;
                            var isActive = semester.StartDate <= DateOnly.FromDateTime(DateTime.Now) 
                                        && semester.EndDate >= DateOnly.FromDateTime(DateTime.Now);
                            <tr>
                                <td>@index</td>
                                <td>@semester.SemesterName</td>
                                <td>@semester.StartDate.ToString("dd/MM/yyyy")</td>
                                <td>@semester.EndDate.ToString("dd/MM/yyyy")</td>
                                <td>
                                    @if (isActive)
                                    {
                                        <span class="badge bg-success">Đang diễn ra</span>
                                    }
                                    else if (semester.EndDate < DateOnly.FromDateTime(DateTime.Now))
                                    {
                                        <span class="badge bg-secondary">Đã kết thúc</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-info">Sắp diễn ra</span>
                                    }
                                </td>
                                <td>
                                    <a asp-page="Details" asp-route-id="@semester.SemesterId" class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-eye"></i> Chi tiết
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="bi bi-calendar-x" style="font-size: 3rem; color: #6c757d;"></i>
                    <p class="text-muted mt-3">Chưa có học kỳ nào</p>
                </div>
            }
        </div>
    </div>
</div>
