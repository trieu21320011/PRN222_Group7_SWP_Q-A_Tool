@page
@model SWP_QA_TOOL.Pages.Instructor.Teams.IndexModel
@{
    ViewData["Title"] = "Danh sách nhóm";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <h3><i class="bi bi-people"></i> Danh sách nhóm</h3>
            <p class="text-muted">Quản lý các nhóm thuộc lớp của bạn</p>
        </div>
    </div>

    <form method="get" class="row mb-3">
        <div class="col-md-4">
            <div class="input-group">
                <input type="text" name="search" class="form-control" placeholder="Tìm kiếm nhóm..." value="@Model.SearchTerm">
                <button class="btn btn-outline-primary" type="submit">
                    <i class="bi bi-search"></i>
                </button>
            </div>
        </div>
        <div class="col-md-3">
            <select name="coreId" class="form-select" onchange="this.form.submit()">
                <option value="">-- Tất cả Lớp --</option>
                @foreach (var core in Model.Cores)
                {
                    <option value="@core.CoreId" selected="@(Model.SelectedCoreId == core.CoreId)">
                        @core.CoreName
                    </option>
                }
            </select>
        </div>
    </form>

    <div class="card">
        <div class="card-body">
            @if (Model.Teams.Any())
            {
                <table class="table table-hover">
                    <thead class="table-light">
                        <tr>
                            <th>#</th>
                            <th>Tên nhóm</th>
                            <th>Lớp</th>
                            <th>Trưởng nhóm</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ var index = 0; }
                        @foreach (var team in Model.Teams)
                        {
                            index++;
                            <tr>
                                <td>@index</td>
                                <td><strong>@team.TeamName</strong></td>
                                <td><span class="badge bg-info">@(team.CoreName ?? "Chưa xác định")</span></td>
                                <td>@(team.LeaderName ?? "Chưa có")</td>
                                <td>
                                    <a asp-page="Details" asp-route-id="@team.TeamId" class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-eye"></i> Chi tiết
                                    </a>
                                    <a asp-page="/Instructor/Questions/Index" asp-route-teamId="@team.TeamId" class="btn btn-sm btn-outline-warning">
                                        <i class="bi bi-chat-dots"></i> Câu hỏi
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="bi bi-people" style="font-size: 3rem; color: #6c757d;"></i>
                    <p class="text-muted mt-3">Không có nhóm nào</p>
                </div>
            }
        </div>
    </div>
</div>
