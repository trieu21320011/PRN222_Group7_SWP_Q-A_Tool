@page
@model SWP_QA_TOOL.Pages.Instructor.Teams.ProgressModel
@{
    ViewData["Title"] = "Tiến độ nhóm";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <h3><i class="bi bi-graph-up"></i> Tiến độ các nhóm</h3>
            <p class="text-muted">Theo dõi câu hỏi chờ trả lời của các nhóm</p>
        </div>
    </div>

    <form method="get" class="row mb-3">
        <div class="col-md-3">
            <select name="coreId" class="form-select" onchange="this.form.submit()">
                <option value="">-- Tất cả Lớp --</option>
                @foreach (var core in Model.Cores)
                {
                    <option value="@core.CoreId" selected="@(Model.SelectedCoreId == core.CoreId)">
                        @core.CoreName
                    </option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <a asp-page="Progress" class="btn btn-outline-secondary">
                <i class="bi bi-x-circle"></i> Xóa bộ lọc
            </a>
        </div>
    </form>

    <!-- Thống kê nhanh -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card border-primary">
                <div class="card-body text-center">
                    <h3 class="text-primary">@Model.Teams.Count()</h3>
                    <small>Tổng số nhóm</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-success">
                <div class="card-body text-center">
                    <h3 class="text-success">@Model.Teams.Count(t => Model.GetPendingQuestionCount(t.TeamId) == 0)</h3>
                    <small>Không có câu hỏi chờ</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-warning">
                <div class="card-body text-center">
                    <h3 class="text-warning">@Model.Teams.Count(t => Model.GetPendingQuestionCount(t.TeamId) > 0 && Model.GetPendingQuestionCount(t.TeamId) <= 3)</h3>
                    <small>1-3 câu hỏi chờ</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-danger">
                <div class="card-body text-center">
                    <h3 class="text-danger">@Model.Teams.Count(t => Model.GetPendingQuestionCount(t.TeamId) > 3)</h3>
                    <small>Nhiều hơn 3 câu hỏi</small>
                </div>
            </div>
        </div>
    </div>

    <!-- Nhóm cần hỗ trợ gấp -->
    @{
        var urgentTeams = Model.Teams.Where(t => Model.GetPendingQuestionCount(t.TeamId) > 3).ToList();
    }
    @if (urgentTeams.Any())
    {
        <div class="row mb-4">
            <div class="col-12">
                <div class="card border-danger">
                    <div class="card-header bg-danger text-white">
                        <h6 class="mb-0"><i class="bi bi-exclamation-triangle"></i> Nhóm cần hỗ trợ gấp (> 3 câu hỏi chờ)</h6>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            @foreach (var team in urgentTeams)
                            {
                                var pendingCount = Model.GetPendingQuestionCount(team.TeamId);
                                <div class="col-md-4 mb-3">
                                    <div class="border rounded p-3">
                                        <div class="d-flex justify-content-between align-items-center mb-2">
                                            <strong>@team.TeamName</strong>
                                            <span class="badge bg-danger">@pendingCount câu hỏi</span>
                                        </div>
                                        <small class="text-muted d-block">@(team.CoreName ?? "Chưa xác định")</small>
                                        <small class="text-muted d-block">@(team.TopicName ?? "Chưa có đề tài")</small>
                                        <div class="mt-2">
                                            <a asp-page="/Instructor/Questions/Index" asp-route-teamName="@team.TeamName" asp-route-status="Open" class="btn btn-sm btn-outline-danger">
                                                <i class="bi bi-chat-text"></i> Trả lời câu hỏi
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header bg-white">
                    <h6 class="mb-0"><i class="bi bi-list-ul"></i> Danh sách tất cả nhóm</h6>
                </div>
                <div class="card-body">
                    @if (Model.Teams.Any())
                    {
                        <table class="table table-hover">
                            <thead class="table-light">
                                <tr>
                                    <th>#</th>
                                    <th>Tên nhóm</th>
                                    <th>Lớp</th>
                                    <th>Đề tài</th>
                                    <th>Trưởng nhóm</th>
                                    <th>Câu hỏi chờ</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @{ var index = 0; }
                                @foreach (var team in Model.Teams.OrderByDescending(t => Model.GetPendingQuestionCount(t.TeamId)))
                                {
                                    index++;
                                    var pendingCount = Model.GetPendingQuestionCount(team.TeamId);
                                    var rowClass = pendingCount > 3 ? "table-danger" : (pendingCount > 0 ? "table-warning" : "");
                                    <tr class="@rowClass">
                                        <td>@index</td>
                                        <td><strong>@team.TeamName</strong></td>
                                        <td><span class="badge bg-info">@(team.CoreName ?? "Chưa xác định")</span></td>
                                        <td>@(team.TopicName ?? "Chưa có")</td>
                                        <td>@(team.LeaderName ?? "Chưa có")</td>
                                        <td>
                                            @if (pendingCount == 0)
                                            {
                                                <span class="badge bg-success">0</span>
                                            }
                                            else if (pendingCount <= 3)
                                            {
                                                <span class="badge bg-warning">@pendingCount</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger">@pendingCount</span>
                                            }
                                        </td>
                                        <td>
                                            <a asp-page="Details" asp-route-id="@team.TeamId" class="btn btn-sm btn-outline-primary">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                            @if (pendingCount > 0)
                                            {
                                                <a asp-page="/Instructor/Questions/Index" asp-route-teamName="@team.TeamName" asp-route-status="Open" class="btn btn-sm btn-outline-warning">
                                                    <i class="bi bi-chat-dots"></i>
                                                </a>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="bi bi-people" style="font-size: 3rem; color: #6c757d;"></i>
                            <p class="text-muted mt-3">Không có nhóm nào</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
