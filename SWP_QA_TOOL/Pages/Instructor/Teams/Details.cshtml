@page "{id:int}"
@model SWP_QA_TOOL.Pages.Instructor.Teams.DetailsModel
@{
    ViewData["Title"] = "Chi tiết Nhóm";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-page="/Instructor/Index">Trang chủ</a></li>
                    <li class="breadcrumb-item"><a asp-page="Index">Nhóm</a></li>
                    <li class="breadcrumb-item active">Chi tiết</li>
                </ol>
            </nav>
        </div>
    </div>

    @if (Model.Team != null)
    {
        <div class="row mb-4">
            <div class="col-md-8">
                <div class="card">
                    <div class="card-header bg-primary text-white">
                        <h4 class="mb-0">
                            <i class="bi bi-people"></i> @Model.Team.TeamName
                        </h4>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6">
                                <p><strong>Trưởng nhóm:</strong> @(Model.Team.LeaderName ?? "Chưa có")</p>
                            </div>
                            <div class="col-md-6">
                                <p><strong>Lớp:</strong>
                                    @if (Model.Team.CoreId.HasValue && !string.IsNullOrEmpty(Model.Team.CoreName))
                                    {
                                        <a asp-page="/Instructor/Cores/Details" asp-route-id="@Model.Team.CoreId" class="badge bg-info text-decoration-none">
                                            @Model.Team.CoreName
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Chưa xác định</span>
                                    }
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="row">
                    <div class="col-6 mb-2">
                        <div class="card bg-warning text-white">
                            <div class="card-body text-center py-3">
                                <h4 class="mb-0">@Model.OpenQuestionCount</h4>
                                <small>Chờ trả lời</small>
                            </div>
                        </div>
                    </div>
                    <div class="col-6 mb-2">
                        <div class="card bg-info text-white">
                            <div class="card-body text-center py-3">
                                <h4 class="mb-0">@Model.AnsweredQuestionCount</h4>
                                <small>Đã trả lời</small>
                            </div>
                        </div>
                    </div>
                    <div class="col-12">
                        <div class="card bg-success text-white">
                            <div class="card-body text-center py-3">
                                <h4 class="mb-0">@Model.ResolvedQuestionCount</h4>
                                <small>Đã giải quyết</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-6 mb-4">
                <div class="card h-100">
                    <div class="card-header bg-white">
                        <h5 class="mb-0"><i class="bi bi-info-circle"></i> Thông tin nhóm</h5>
                    </div>
                    <div class="card-body">
                        <p><strong>Tên nhóm:</strong> @Model.Team.TeamName</p>
                        <p><strong>Code:</strong> @(Model.Team.TeamCode ?? "Chưa có")</p>
                        <p><strong>Lớp:</strong>
                            @if (Model.Team.CoreId.HasValue && !string.IsNullOrEmpty(Model.Team.CoreName))
                            {
                                <a asp-page="/Instructor/Cores/Details" asp-route-id="@Model.Team.CoreId" class="badge bg-info text-decoration-none">
                                    @Model.Team.CoreName
                                </a>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Chưa xác định</span>
                            }
                        </p>
                        <p><strong>Trưởng nhóm:</strong> @(Model.Team.LeaderName ?? "Chưa có")</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6 mb-4">
                <div class="card h-100">
                    <div class="card-header bg-white d-flex justify-content-between align-items-center">
                        <h5 class="mb-0"><i class="bi bi-chat-left-text"></i> Câu hỏi gần đây
                            @if (Model.Team.TopicId.HasValue)
                            {
                                <small class="text-muted ms-2">(Lọc theo đề tài)</small>
                            }
                        </h5>
                        <a asp-page="/Instructor/Questions/Index"
                           asp-route-teamId="@Model.Team.TeamId"
                           asp-route-topicId="@Model.Team.TopicId"
                           class="btn btn-sm btn-outline-primary">
                            Xem tất cả
                        </a>
                    </div>
                    <div class="card-body">
                        @if (Model.Questions.Any())
                        {
                            <ul class="list-group list-group-flush">
                                @foreach (var question in Model.Questions.OrderByDescending(q => q.CreatedAt).Take(5))
                                {
                                    <li class="list-group-item">
                                        <div class="d-flex justify-content-between align-items-start">
                                            <div>
                                                <a asp-page="/Instructor/Questions/Answer" asp-route-id="@question.QuestionId" class="text-decoration-none fw-semibold">
                                                    @question.Title
                                                </a>
                                                @if (!string.IsNullOrEmpty(question.AssignedInstructorName))
                                                {
                                                    <br /><small class="text-muted"><i class="bi bi-person-check"></i> @question.AssignedInstructorName</small>
                                                }
                                            </div>
                                            <div class="d-flex gap-1">
                                                @if (question.Status == "Open")
                                                {
                                                    <span class="badge bg-warning">Mở</span>
                                                }
                                                else if (question.Status == "Answered")
                                                {
                                                    <span class="badge bg-info">Đã trả lời</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-success">Giải quyết</span>
                                                }
                                                @if (question.AssignedInstructorId == Model.CurrentUserId && question.Status == "Open")
                                                {
                                                    <a asp-page="/Instructor/Questions/Answer" asp-route-id="@question.QuestionId" class="badge bg-primary text-decoration-none">Trả lời</a>
                                                }
                                            </div>
                                        </div>
                                        <small class="text-muted">
                                            @if (question.CreatedAt.HasValue)
                                            {
                                                @question.CreatedAt.Value.ToString("dd/MM/yyyy HH:mm")
                                            }
                                        </small>
                                    </li>
                                }
                            </ul>
                        }
                        else
                        {
                            <div class="text-center text-muted py-3">
                                <i class="bi bi-inbox"></i> Chưa có câu hỏi
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-warning">
            <i class="bi bi-exclamation-triangle"></i> Không tìm thấy nhóm
        </div>
    }

    <div class="mt-4">
        <a asp-page="Index" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Quay lại
        </a>
    </div>
</div>
