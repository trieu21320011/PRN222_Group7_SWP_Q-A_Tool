@page
@model SWP_QA_TOOL.Pages.Instructor.IndexModel
@{
    ViewData["Title"] = "Trang chủ Giảng viên";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <h2><i class="bi bi-house-door"></i> Xin chào, Giảng viên!</h2>
            <p class="text-muted">Tổng quan hoạt động và thống kê</p>
        </div>
    </div>

    <!-- Thống kê nhanh -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card bg-primary text-white h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="card-title">Học kỳ hoạt động</h6>
                            <h2 class="mb-0">1</h2>
                        </div>
                        <i class="bi bi-calendar-check" style="font-size: 2.5rem; opacity: 0.5;"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-success text-white h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="card-title">Đề tài phụ trách</h6>
                            <h2 class="mb-0">5</h2>
                        </div>
                        <i class="bi bi-journal-bookmark" style="font-size: 2.5rem; opacity: 0.5;"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-info text-white h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="card-title">Nhóm quản lý</h6>
                            <h2 class="mb-0">12</h2>
                        </div>
                        <i class="bi bi-people" style="font-size: 2.5rem; opacity: 0.5;"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-warning text-white h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="card-title">Câu hỏi chờ trả lời</h6>
                            <h2 class="mb-0">8</h2>
                        </div>
                        <i class="bi bi-question-circle" style="font-size: 2.5rem; opacity: 0.5;"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- Câu hỏi mới nhất -->
        <div class="col-md-6 mb-4">
            <div class="card h-100">
                <div class="card-header bg-white">
                    <h5 class="mb-0"><i class="bi bi-chat-left-text text-primary"></i> Câu hỏi mới nhất</h5>
                </div>
                <div class="card-body">
                    <ul class="list-group list-group-flush">
                        <li class="list-group-item d-flex justify-content-between align-items-start">
                            <div class="ms-2 me-auto">
                                <div class="fw-bold">Câu hỏi về Use Case Diagram</div>
                                <small class="text-muted">Nhóm 1 - 10 phút trước</small>
                            </div>
                            <span class="badge bg-warning rounded-pill">Chờ trả lời</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-start">
                            <div class="ms-2 me-auto">
                                <div class="fw-bold">Hỏi về Database Design</div>
                                <small class="text-muted">Nhóm 3 - 30 phút trước</small>
                            </div>
                            <span class="badge bg-warning rounded-pill">Chờ trả lời</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-start">
                            <div class="ms-2 me-auto">
                                <div class="fw-bold">Xác nhận requirement</div>
                                <small class="text-muted">Nhóm 2 - 1 giờ trước</small>
                            </div>
                            <span class="badge bg-success rounded-pill">Đã trả lời</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-start">
                            <div class="ms-2 me-auto">
                                <div class="fw-bold">Hướng dẫn deploy ứng dụng</div>
                                <small class="text-muted">Nhóm 5 - 2 giờ trước</small>
                            </div>
                            <span class="badge bg-success rounded-pill">Đã trả lời</span>
                        </li>
                    </ul>
                </div>
                <div class="card-footer bg-white">
                    <a href="/Instructor/Questions/Index" class="btn btn-sm btn-outline-primary">
                        Xem tất cả <i class="bi bi-arrow-right"></i>
                    </a>
                </div>
            </div>
        </div>

        <!-- Nhóm cần theo dõi -->
        <div class="col-md-6 mb-4">
            <div class="card h-100">
                <div class="card-header bg-white">
                    <h5 class="mb-0"><i class="bi bi-people text-success"></i> Tiến độ các nhóm</h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <div class="d-flex justify-content-between mb-1">
                            <span>Nhóm 1 - SWP391</span>
                            <span>85%</span>
                        </div>
                        <div class="progress">
                            <div class="progress-bar bg-success" style="width: 85%"></div>
                        </div>
                    </div>
                    <div class="mb-3">
                        <div class="d-flex justify-content-between mb-1">
                            <span>Nhóm 2 - SWP391</span>
                            <span>70%</span>
                        </div>
                        <div class="progress">
                            <div class="progress-bar bg-info" style="width: 70%"></div>
                        </div>
                    </div>
                    <div class="mb-3">
                        <div class="d-flex justify-content-between mb-1">
                            <span>Nhóm 3 - PRN231</span>
                            <span>50%</span>
                        </div>
                        <div class="progress">
                            <div class="progress-bar bg-warning" style="width: 50%"></div>
                        </div>
                    </div>
                    <div class="mb-3">
                        <div class="d-flex justify-content-between mb-1">
                            <span>Nhóm 4 - PRN231</span>
                            <span>30%</span>
                        </div>
                        <div class="progress">
                            <div class="progress-bar bg-danger" style="width: 30%"></div>
                        </div>
                    </div>
                </div>
                <div class="card-footer bg-white">
                    <a href="/Instructor/Teams/Progress" class="btn btn-sm btn-outline-success">
                        Xem chi tiết <i class="bi bi-arrow-right"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
