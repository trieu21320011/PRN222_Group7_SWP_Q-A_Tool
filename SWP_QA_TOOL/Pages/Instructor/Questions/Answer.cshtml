@page "{id:int}"
@model SWP_QA_TOOL.Pages.Instructor.Questions.AnswerModel
@{
    ViewData["Title"] = "Trả lời câu hỏi";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-page="Index">Câu hỏi</a></li>
                    <li class="breadcrumb-item active">Trả lời</li>
                </ol>
            </nav>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="bi bi-check-circle"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="bi bi-exclamation-triangle"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (Model.Question != null)
    {
        <div class="row">
            <div class="col-md-8">
                <!-- Nội dung câu hỏi -->
                <div class="card mb-4">
                    <div class="card-header @(Model.Question.Status == "Open" ? "bg-warning text-dark" : Model.Question.Status == "Answered" ? "bg-info text-white" : "bg-success text-white")">
                        <h5 class="mb-0"><i class="bi bi-question-circle"></i> @Model.Question.Title</h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            @if (Model.Team != null)
                            {
                                <span class="badge bg-info">@Model.Team.TeamName</span>
                                <span class="badge bg-secondary">@(Model.Team.CoreName ?? "Lớp")</span>
                            }
                            @if (Model.Question.Status == "Open")
                            {
                                <span class="badge bg-warning">Chờ trả lời</span>
                            }
                            else if (Model.Question.Status == "Answered")
                            {
                                <span class="badge bg-info">Đã trả lời</span>
                            }
                            else
                            {
                                <span class="badge bg-success">Đã giải quyết</span>
                            }
                        </div>
                        <p class="text-muted">
                            <i class="bi bi-person"></i> Hỏi bởi: <strong>@(Model.Question.AuthorName ?? "Ẩn danh")</strong> -
                            <i class="bi bi-clock"></i>
                            @if (Model.Question.CreatedAt.HasValue)
                            {
                                @Model.Question.CreatedAt.Value.ToString("dd/MM/yyyy HH:mm")
                            }
                        </p>
                        <hr>
                        <div class="question-content">
                            @Html.Raw(Model.Question.Body?.Replace("\n", "<br/>") ?? "Không có nội dung")
                        </div>
                    </div>

                    <!-- Follow-up questions (Comments) for the question -->
                    @if (Model.QuestionComments.Any())
                    {
                        <div class="card-footer bg-light">
                            <h6 class="mb-3"><i class="bi bi-chat-dots"></i> Hỏi thêm (@Model.QuestionComments.Count)</h6>
                            @foreach (var comment in Model.QuestionComments.OrderBy(c => c.CreatedAt))
                            {
                                <div class="d-flex mb-2 ps-3 border-start border-primary border-2">
                                    <div class="flex-grow-1">
                                        <div class="d-flex justify-content-between">
                                            <small class="text-primary fw-bold">@(comment.AuthorName ?? "Người dùng")</small>
                                            <small class="text-muted">@(comment.CreatedAt?.ToString("dd/MM/yyyy HH:mm") ?? "")</small>
                                        </div>
                                        <p class="mb-0 small">@Html.Raw(comment.Body?.Replace("\n", "<br/>") ?? "")</p>
                                    </div>
                                </div>
                            }
                        </div>
                    }

                    <!-- Form to add follow-up question to question -->
                    <div class="card-footer">
                        <form method="post" asp-page-handler="AddQuestionComment">
                            <input type="hidden" name="questionId" value="@Model.Question.QuestionId" />
                            <div class="input-group">
                                <input type="text" name="commentBody" class="form-control form-control-sm" placeholder="Thêm phản hồi..." />
                                <button type="submit" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-send"></i>
                                </button>
                            </div>
                        </form>
                    </div>
                </div>

                <!-- Existing Answers -->
                @if (Model.Answers.Any())
                {
                    <div class="card mb-4">
                        <div class="card-header bg-light">
                            <h6 class="mb-0"><i class="bi bi-chat-left-quote"></i> Các câu trả lời (@Model.Answers.Count())</h6>
                        </div>
                        <div class="card-body">
                            @foreach (var answer in Model.Answers.OrderByDescending(a => a.CreatedAt))
                            {
                                <div class="border rounded p-3 mb-3">
                                    <div class="d-flex justify-content-between mb-2">
                                        <strong><i class="bi bi-person-check"></i> @(answer.AuthorName ?? "Giảng viên")</strong>
                                        <small class="text-muted">
                                            @if (answer.CreatedAt.HasValue)
                                            {
                                                @answer.CreatedAt.Value.ToString("dd/MM/yyyy HH:mm")
                                            }
                                        </small>
                                    </div>
                                    <p class="mb-2">@Html.Raw(answer.Body?.Replace("\n", "<br/>"))</p>

                                    <!-- Follow-up questions for this answer -->
                                    @if (Model.AnswerComments.ContainsKey(answer.AnswerId) && Model.AnswerComments[answer.AnswerId].Any())
                                    {
                                        <div class="bg-light rounded p-2 mb-2">
                                            <small class="text-muted d-block mb-2"><i class="bi bi-chat-dots"></i> Hỏi thêm (@Model.AnswerComments[answer.AnswerId].Count)</small>
                                            @foreach (var comment in Model.AnswerComments[answer.AnswerId].OrderBy(c => c.CreatedAt))
                                            {
                                                <div class="d-flex mb-2 ps-2 border-start border-info border-2">
                                                    <div class="flex-grow-1">
                                                        <div class="d-flex justify-content-between">
                                                            <small class="text-info fw-bold">@(comment.AuthorName ?? "Người dùng")</small>
                                                            <small class="text-muted">@(comment.CreatedAt?.ToString("dd/MM HH:mm") ?? "")</small>
                                                        </div>
                                                        <p class="mb-0 small">@Html.Raw(comment.Body?.Replace("\n", "<br/>") ?? "")</p>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    }

                                    <!-- Form to add follow-up to this answer -->
                                    <form method="post" asp-page-handler="AddAnswerComment" class="mt-2">
                                        <input type="hidden" name="questionId" value="@Model.Question.QuestionId" />
                                        <input type="hidden" name="answerId" value="@answer.AnswerId" />
                                        <div class="input-group input-group-sm">
                                            <input type="text" name="commentBody" class="form-control form-control-sm" placeholder="Thêm phản hồi về câu trả lời này..." />
                                            <button type="submit" class="btn btn-outline-info btn-sm">
                                                <i class="bi bi-reply"></i>
                                            </button>
                                        </div>
                                    </form>
                                </div>
                            }
                        </div>
                    </div>
                }

                <!-- Form trả lời -->
                @if (Model.Question.Status != "Resolved")
                {
                    <div class="card">
                        <div class="card-header bg-success text-white">
                            <h5 class="mb-0"><i class="bi bi-reply"></i> @(Model.Answers.Any() ? "Thêm trả lời" : "Câu trả lời của bạn")</h5>
                        </div>
                        <div class="card-body">
                            <form method="post" asp-route-id="@Model.Question.QuestionId">
                                <div class="mb-3">
                                    <label asp-for="Input.Content" class="form-label">Nội dung trả lời <span class="text-danger">*</span></label>
                                    <textarea asp-for="Input.Content" class="form-control" rows="8" placeholder="Nhập câu trả lời của bạn..."></textarea>
                                    <span asp-validation-for="Input.Content" class="text-danger"></span>
                                    <div class="form-text">Hỗ trợ định dạng văn bản thông thường</div>
                                </div>
                                <div class="mb-3 form-check">
                                    <input asp-for="Input.MarkResolved" type="checkbox" class="form-check-input" id="markResolved">
                                    <label asp-for="Input.MarkResolved" class="form-check-label" for="markResolved">Đánh dấu câu hỏi đã được giải quyết</label>
                                </div>
                                <div class="d-flex gap-2">
                                    <button type="submit" class="btn btn-success">
                                        <i class="bi bi-send"></i> Gửi trả lời
                                    </button>
                                    <a asp-page="Index" class="btn btn-outline-secondary">
                                        <i class="bi bi-arrow-left"></i> Quay lại
                                    </a>
                                </div>
                            </form>
                        </div>
                    </div>
                }
                else
                {
                    <div class="card">
                        <div class="card-body text-center">
                            <i class="bi bi-check-circle text-success" style="font-size: 2rem;"></i>
                            <p class="mt-2 text-success">Câu hỏi này đã được giải quyết</p>
                            <a asp-page="Index" class="btn btn-outline-primary">
                                <i class="bi bi-arrow-left"></i> Quay lại danh sách
                            </a>
                        </div>
                    </div>
                }
            </div>

            <div class="col-md-4">
                <!-- Thông tin nhóm -->
                @if (Model.Team != null)
                {
                    <div class="card mb-3">
                        <div class="card-header bg-light">
                            <h6 class="mb-0"><i class="bi bi-people"></i> Thông tin nhóm</h6>
                        </div>
                        <div class="card-body">
                            <p><strong>Tên nhóm:</strong> @Model.Team.TeamName</p>
                            <p><strong>Lớp:</strong> @(Model.Team.CoreName ?? "Chưa xác định")</p>
                            <p><strong>Trưởng nhóm:</strong> @(Model.Team.LeaderName ?? "Chưa có")</p>
                            <a asp-page="/Instructor/Teams/Details" asp-route-id="@Model.Team.TeamId" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-eye"></i> Xem nhóm
                            </a>
                        </div>
                    </div>
                }

                <!-- Quick Actions -->
                @if (Model.Question.Status == "Answered")
                {
                    <div class="card mb-3">
                        <div class="card-header bg-light">
                            <h6 class="mb-0"><i class="bi bi-lightning"></i> Thao tác nhanh</h6>
                        </div>
                        <div class="card-body">
                            <form method="post" asp-page-handler="MarkResolved" asp-route-id="@Model.Question.QuestionId">
                                <button type="submit" class="btn btn-success w-100">
                                    <i class="bi bi-check-circle"></i> Đánh dấu đã giải quyết
                                </button>
                            </form>
                        </div>
                    </div>
                }

                <!-- Câu hỏi khác của nhóm -->
                <div class="card">
                    <div class="card-header bg-light">
                        <h6 class="mb-0"><i class="bi bi-clock-history"></i> Câu hỏi khác của nhóm</h6>
                    </div>
                    <div class="list-group list-group-flush">
                        @if (Model.OtherTeamQuestions.Any())
                        {
                            @foreach (var q in Model.OtherTeamQuestions)
                            {
                                <a asp-page="Answer" asp-route-id="@q.QuestionId" class="list-group-item list-group-item-action">
                                    <div class="d-flex justify-content-between">
                                        <small class="text-truncate" style="max-width: 150px;">@q.Title</small>
                                        @if (q.Status == "Open")
                                        {
                                            <span class="badge bg-warning">Mở</span>
                                        }
                                        else if (q.Status == "Answered")
                                        {
                                            <span class="badge bg-info">TL</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">OK</span>
                                        }
                                    </div>
                                    <small class="text-muted">
                                        @if (q.CreatedAt.HasValue)
                                        {
                                            var timeAgo = DateTime.Now - q.CreatedAt.Value;
                                            if (timeAgo.TotalDays < 1)
                                            {
                                                @($"{(int)timeAgo.TotalHours} giờ trước")
                                            }
                                            else
                                            {
                                                @($"{(int)timeAgo.TotalDays} ngày trước")
                                            }
                                        }
                                    </small>
                                </a>
                            }
                        }
                        else
                        {
                            <div class="list-group-item text-center text-muted">
                                <small>Không có câu hỏi khác</small>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-warning">
            <i class="bi bi-exclamation-triangle"></i> Không tìm thấy câu hỏi
        </div>
        <a asp-page="Index" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Quay lại
        </a>
    }
</div>
