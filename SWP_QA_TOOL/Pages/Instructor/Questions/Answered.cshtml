                                <i class="bi bi-pencil"></i> Sửa
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card mb-3 border-success">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <h5 class="card-title mb-1">
                                <a href="/Instructor/Questions/Details" class="text-decoration-none">
                                    Hỏi về cấu trúc thư mục dự án
                                </a>
                                <span class="badge bg-success ms-2">Đã trả lời</span>
                            </h5>
                            <p class="text-muted mb-2">
