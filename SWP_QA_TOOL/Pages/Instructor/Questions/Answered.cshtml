                            <h5 class="card-title mb-1">
                                <a href="/Instructor/Questions/Details" class="text-decoration-none">
                                    Xác nhận requirement
                                </a>
                                <span class="badge bg-primary ms-2">Đã giải quyết</span>
                            </h5>
                            <p class="text-muted mb-2">
                                <span class="badge bg-info">Nhóm 2</span>
                                <span class="badge bg-secondary">Core A</span>
                                <small class="ms-2">Hỏi bởi: Lê Văn C - Trả lời: 1 giờ trước</small>
                            </p>
                            <p class="card-text">
                                <i class="bi bi-chat-right-quote"></i> 
                                <em>"Requirement đã được xác nhận. Nhóm có thể tiến hành implement..."</em>
                            </p>
                        </div>
                        <div>
                            <a href="/Instructor/Questions/Details" class="btn btn-outline-primary">
                                <i class="bi bi-eye"></i> Xem chi tiết
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card mb-3 border-success">
                <div class="card-body">
