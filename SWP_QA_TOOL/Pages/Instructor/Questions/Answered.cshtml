@page
@model SWP_QA_TOOL.Pages.Instructor.Questions.AnsweredModel
@{
    ViewData["Title"] = "Câu hỏi đã trả lời";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <h3><i class="bi bi-check-circle text-success"></i> Câu hỏi đã trả lời</h3>
            <p class="text-muted">Các câu hỏi bạn đã phản hồi</p>
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-md-4">
            <div class="input-group">
                <input type="text" class="form-control" placeholder="Tìm kiếm...">
                <button class="btn btn-outline-primary" type="button">
                    <i class="bi bi-search"></i>
                </button>
            </div>
        </div>
        <div class="col-md-2">
            <select class="form-select">
                <option selected>-- Lớp --</option>
                <option>SE1234</option>
                <option>SE1235</option>
            </select>
        </div>
        <div class="col-md-2">
            <select class="form-select">
                <option selected>-- Thời gian --</option>
                <option>Hôm nay</option>
                <option>Tuần này</option>
                <option>Tháng này</option>
            </select>
        </div>
    </div>

    <div class="alert alert-success">
        <i class="bi bi-check-circle"></i> Bạn đã trả lời <strong>25</strong> câu hỏi
    </div>

