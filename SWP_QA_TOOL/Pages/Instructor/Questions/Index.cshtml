@page
@model SWP_QA_TOOL.Pages.Instructor.Questions.IndexModel
@{
    ViewData["Title"] = "Danh sách câu hỏi";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <h3><i class="bi bi-question-circle"></i> Danh sách câu hỏi</h3>
            <p class="text-muted">Quản lý các câu hỏi từ sinh viên</p>
        </div>
    </div>

    <form method="get" class="row mb-3">
        <div class="col-md-3">
            <div class="input-group">
                <input type="text" name="search" class="form-control" placeholder="Tìm kiếm câu hỏi..." value="@Model.SearchTerm">
                <button class="btn btn-outline-primary" type="submit">
                    <i class="bi bi-search"></i>
                </button>
            </div>
        </div>
        <div class="col-md-2">
            <select name="coreId" class="form-select" onchange="this.form.submit()">
                <option value="">-- Lớp --</option>
                @foreach (var core in Model.Cores)
                {
                    <option value="@core.CoreId" selected="@(Model.SelectedCoreId == core.CoreId)">
                        @core.CoreName
                    </option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <select name="teamName" class="form-select" onchange="this.form.submit()">
                <option value="">-- Nhóm --</option>
                @foreach (var team in Model.Teams)
                {
                    <option value="@team.TeamName" selected="@(Model.SelectedTeamName == team.TeamName)">
                        @team.TeamName
                    </option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <select name="status" class="form-select" onchange="this.form.submit()">
                <option value="">-- Trạng thái --</option>
                <option value="Open" selected="@(Model.SelectedStatus == "Open")">Chờ trả lời</option>
                <option value="Answered" selected="@(Model.SelectedStatus == "Answered")">Đã trả lời</option>
                <option value="Resolved" selected="@(Model.SelectedStatus == "Resolved")">Đã giải quyết</option>
            </select>
        </div>
        <div class="col-md-2">
            <a asp-page="Index" class="btn btn-outline-secondary w-100">
                <i class="bi bi-x-circle"></i> Xóa bộ lọc
            </a>
        </div>
    </form>

    <!-- Thống kê nhanh -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card border-warning">
                <div class="card-body text-center">
                    <h3 class="text-warning">@Model.OpenCount</h3>
                    <small>Chờ trả lời</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-info">
                <div class="card-body text-center">
                    <h3 class="text-info">@Model.AnsweredCount</h3>
                    <small>Đã trả lời</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-success">
                <div class="card-body text-center">
                    <h3 class="text-success">@Model.ResolvedCount</h3>
                    <small>Đã giải quyết</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-primary">
                <div class="card-body text-center">
                    <h3 class="text-primary">@Model.Questions.Count()</h3>
                    <small>Tổng câu hỏi</small>
                </div>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            @if (Model.Questions.Any())
            {
                <table class="table table-hover">
                    <thead class="table-light">
                        <tr>
                            <th>#</th>
                            <th>Tiêu đề</th>
                            <th>Nhóm</th>
                            <th>Người hỏi</th>
                            <th>Thời gian</th>
                            <th>Trạng thái</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ var index = 0; }
                        @foreach (var question in Model.Questions)
                        {
                            index++;
                            var rowClass = question.Status == "Open" ? "table-warning" : "";
                            <tr class="@rowClass">
                                <td>@index</td>
                                <td>
                                    <a asp-page="Answer" asp-route-id="@question.QuestionId" class="text-decoration-none">
                                        @question.Title
                                    </a>
                                </td>
                                <td><span class="badge bg-secondary">@(question.TeamName ?? "Chưa xác định")</span></td>
                                <td>@(question.AuthorName ?? "Ẩn danh")</td>
                                <td>
                                    @if (question.CreatedAt.HasValue)
                                    {
                                        var timeAgo = DateTime.Now - question.CreatedAt.Value;
                                        if (timeAgo.TotalMinutes < 60)
                                        {
                                            @($"{(int)timeAgo.TotalMinutes} phút trước")
                                        }
                                        else if (timeAgo.TotalHours < 24)
                                        {
                                            @($"{(int)timeAgo.TotalHours} giờ trước")
                                        }
                                        else
                                        {
                                            @($"{(int)timeAgo.TotalDays} ngày trước")
                                        }
                                    }
                                </td>
                                <td>
                                    @if (question.Status == "Open")
                                    {
                                        <span class="badge bg-warning">Chờ trả lời</span>
                                    }
                                    else if (question.Status == "Answered")
                                    {
                                        <span class="badge bg-info">Đã trả lời</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">Đã giải quyết</span>
                                    }
                                </td>
                                <td>
                                    @if (question.Status == "Open")
                                    {
                                        <a asp-page="Answer" asp-route-id="@question.QuestionId" class="btn btn-sm btn-success">
                                            <i class="bi bi-reply"></i> Trả lời
                                        </a>
                                    }
                                    else
                                    {
                                        <a asp-page="Answer" asp-route-id="@question.QuestionId" class="btn btn-sm btn-outline-primary">
                                            <i class="bi bi-eye"></i> Xem
                                        </a>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="bi bi-inbox" style="font-size: 3rem; color: #6c757d;"></i>
                    <p class="text-muted mt-3">Không có câu hỏi nào</p>
                </div>
            }
        </div>
    </div>
</div>
