<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Quản Trị - SWP QA Tool</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark admin-navbar">
            <div class="container-fluid">
                <a class="navbar-brand" href="/Admin">
                    <i class="bi bi-shield-lock-fill"></i> SWP QA Tool - Admin
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item">
                            <a class="nav-link" href="#">
                                <i class="bi bi-bell"></i>
                                <span class="badge bg-danger">3</span>
                            </a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown">
                                <i class="bi bi-person-circle"></i>
                                @if (User.Identity?.IsAuthenticated == true)
                                {
                                    @User.Identity.Name
                                }
                                else
                                {
                                    <span>Admin</span>
                                }
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><a class="dropdown-item" href="/"><i class="bi bi-house"></i> Trang chủ</a></li>
                                <li><a class="dropdown-item" href="#"><i class="bi bi-person"></i> Hồ sơ</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" asp-page="/Account/Logout"><i class="bi bi-box-arrow-right"></i> Đăng xuất</a></li>
                            </ul>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container-fluid">
        <div class="row">
            <!-- Sidebar -->
            <nav class="col-md-3 col-lg-2 d-md-block sidebar collapse">
                <div class="sidebar-header">
                    <i class="bi bi-speedometer2"></i> Bảng điều khiển
                </div>
                <div class="position-sticky pt-3">
                    <!-- Dashboard -->
                    <div class="nav-section-title">Tổng quan</div>
                    <ul class="nav flex-column">
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Admin/Index">
                                <i class="bi bi-house-door"></i> Dashboard
                            </a>
                        </li>
                    </ul>

                    <!-- Quản lý người dùng -->
                    <div class="nav-section-title nav-section">Quản lý người dùng</div>
                    <ul class="nav flex-column">
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Admin/Users/Index">
                                <i class="bi bi-people"></i> Danh sách người dùng
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Admin/Users/Create">
                                <i class="bi bi-person-plus"></i> Thêm người dùng
                            </a>
                        </li>
                    </ul>

                    <!-- Quản lý học kỳ -->
                    <div class="nav-section-title nav-section">Quản lý học kỳ</div>
                    <ul class="nav flex-column">
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Admin/Semesters/Index">
                                <i class="bi bi-calendar3"></i> Học kỳ
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Admin/Topics/Index">
                                <i class="bi bi-journal-bookmark"></i> Đề tài
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Admin/Cores/Index">
                                <i class="bi bi-collection"></i> Lớp học
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Admin/Cores/AssignInstructor">
                                <i class="bi bi-person-badge"></i> Phân công giảng viên
                            </a>
                        </li>
                    </ul>

                    <!-- Quản lý Q&A -->
                    <div class="nav-section-title nav-section">Quản lý Q&A</div>
                    <ul class="nav flex-column">
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Admin/Questions/Index">
                                <i class="bi bi-question-circle"></i> Câu hỏi
                            </a>
                        </li>
                    </ul>

                    <!-- Quản lý hệ thống -->
                    <div class="nav-section-title nav-section">Hệ thống</div>
                    <ul class="nav flex-column">
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Admin/SystemInstructors/Index">
                                <i class="bi bi-gear"></i> System Instructors
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Admin/Notifications/Index">
                                <i class="bi bi-bell"></i> Thông báo
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Admin/Reports/Index">
                                <i class="bi bi-file-earmark-bar-graph"></i> Báo cáo
                            </a>
                        </li>
                    </ul>
                </div>
            </nav>

            <!-- Main content -->
            <main class="col-md-9 ms-sm-auto col-lg-10 content-wrapper">
                @RenderBody()
            </main>
        </div>
    </div>

    <!-- Footer -->
    <footer class="admin-footer">
        <div class="container-fluid">
            <div class="row align-items-center">
                <div class="col-md-6">
                    <span class="text-muted">&copy; 2026 SWP QA Tool - Admin Panel</span>
                </div>
                <div class="col-md-6 text-end">
                    <span class="text-muted">Version 1.0.0</span>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
