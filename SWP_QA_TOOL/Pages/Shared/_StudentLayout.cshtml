<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Sinh Viên - SWP QA Tool</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/student.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark student-navbar">
            <div class="container-fluid">
                <a class="navbar-brand" href="/Student">
                    <i class="bi bi-mortarboard-fill"></i> SWP QA Tool - Sinh Viên
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown">
                                <i class="bi bi-person-circle"></i>
                                @if (User.Identity?.IsAuthenticated == true)
                                {
                                    @User.Identity.Name
                                }
                                else
                                {
                                    <span>Sinh Viên</span>
                                }
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><a class="dropdown-item" href="/"><i class="bi bi-house"></i> Trang chủ</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" asp-page="/Account/Logout"><i class="bi bi-box-arrow-right"></i> Đăng xuất</a></li>
                            </ul>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container-fluid">
        <div class="row">
            <!-- Sidebar -->
            <nav class="col-md-3 col-lg-2 d-md-block sidebar collapse">
                <div class="sidebar-header">
                    <i class="bi bi-person"></i> Sinh Viên
                </div>
                <div class="position-sticky pt-3">
                    <!-- Xem thông tin cá nhân -->
                    <div class="nav-section-title">Thông tin cá nhân</div>
                    <ul class="nav flex-column">
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Student/Cores/Index">
                                <i class="bi bi-collection"></i> Lớp của tôi
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Student/Teams/MyTeam">
                                <i class="bi bi-people"></i> Nhóm của tôi
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Student/Topics/Index">
                                <i class="bi bi-journal-bookmark"></i> Đề tài đăng ký
                            </a>
                        </li>
                    </ul>

                    <!-- Quản lý nhóm -->
                    <div class="nav-section-title nav-section">Quản lý nhóm</div>
                    <ul class="nav flex-column">
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Student/Teams/MyTeam">
                                <i class="bi bi-people-fill"></i> Nhóm của tôi
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Student/Teams/Create">
                                <i class="bi bi-plus-circle"></i> Tạo nhóm mới
                            </a>
                        </li>
                    </ul>

                    <!-- Đặt câu hỏi cho GV -->
                    <div class="nav-section-title nav-section">Câu hỏi - Hỏi đáp</div>
                    <ul class="nav flex-column">
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Student/Questions/Create">
                                <i class="bi bi-plus-square"></i> Tạo câu hỏi
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Student/Questions/Index">
                                <i class="bi bi-question-circle"></i> Câu hỏi của nhóm
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Student/Questions/Answered">
                                <i class="bi bi-check-circle"></i> Đã được trả lời
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Student/Questions/Pending">
                                <i class="bi bi-hourglass-split"></i> Chờ trả lời
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Student/Questions/History">
                                <i class="bi bi-clock-history"></i> Lịch sử hỏi đáp
                            </a>
                        </li>
                    </ul>
                </div>
            </nav>

            <!-- Main content -->
            <main class="col-md-9 ms-sm-auto col-lg-10 content-wrapper">
                @RenderBody()
            </main>
        </div>
    </div>

    <!-- Footer -->
    <footer class="student-footer">
        <div class="container-fluid">
            <div class="row align-items-center">
                <div class="col-md-6">
                    <span class="text-muted">&copy; 2026 SWP QA Tool - Sinh Viên Portal</span>
                </div>
                <div class="col-md-6 text-end">
                    <span class="text-muted">Version 1.0.0</span>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
