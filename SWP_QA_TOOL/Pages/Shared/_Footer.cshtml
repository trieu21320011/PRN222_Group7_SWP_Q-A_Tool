@* Footer Partial View - Reusable across layouts *@
@{
    var footerClass = ViewData["FooterClass"]?.ToString() ?? "default-footer";
    var footerText = ViewData["FooterText"]?.ToString() ?? "SWP QA Tool";
}

<footer class="@footerClass">
    <div class="container-fluid">
        <div class="row align-items-center">
            <div class="col-md-4">
                <div class="footer-brand">
                    <i class="bi bi-mortarboard-fill"></i>
                    <span>SWP QA Tool</span>
                </div>
                <p class="text-muted small mb-0">Hệ thống hỗ trợ hỏi đáp dự án phần mềm</p>
            </div>
            <div class="col-md-4 text-center">
                <ul class="list-inline mb-0">
                    <li class="list-inline-item">
                        <a href="#" class="footer-link">Hướng dẫn</a>
                    </li>
                    <li class="list-inline-item">
                        <a href="#" class="footer-link">Liên hệ</a>
                    </li>
                    <li class="list-inline-item">
                        <a href="#" class="footer-link">Điều khoản</a>
                    </li>
                </ul>
            </div>
            <div class="col-md-4 text-end">
                <span class="text-muted">&copy; @DateTime.Now.Year @footerText</span>
                <br />
                <small class="text-muted">Version 1.0.0</small>
            </div>
        </div>
    </div>
</footer>
