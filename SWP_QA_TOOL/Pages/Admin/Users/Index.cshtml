@page
@model SWP_QA_TOOL.Pages.Admin.Users.IndexModel
@{
    ViewData["Title"] = "Quản lý người dùng";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h3><i class="bi bi-people"></i> Quản lý người dùng</h3>
                    <p class="text-muted mb-0">Danh sách tất cả người dùng trong hệ thống</p>
                </div>
                <a href="/Admin/Users/Create" class="btn btn-admin-primary">
                    <i class="bi bi-person-plus"></i> Thêm người dùng
                </a>
            </div>
        </div>
    </div>

    <!-- Filter -->
    <div class="card mb-4">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-3">
                    <input type="text" class="form-control" placeholder="Tìm kiếm theo tên...">
                </div>
                <div class="col-md-2">
                    <select class="form-select">
                        <option selected>-- Tất cả Role --</option>
                        <option>Admin</option>
                        <option>Instructor</option>
                        <option>Student</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <select class="form-select">
                        <option selected>-- Trạng thái --</option>
                        <option>Hoạt động</option>
                        <option>Bị khóa</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <button class="btn btn-outline-primary w-100">
                        <i class="bi bi-search"></i> Tìm kiếm
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Users Table -->
    <div class="card">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Họ tên</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Ngày tạo</th>
                        <th>Trạng thái</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>1</td>
                        <td>
                            <div class="d-flex align-items-center">
                                <img src="https://ui-avatars.com/api/?name=Admin&background=8e44ad&color=fff" 
                                     class="rounded-circle me-2" width="36" height="36">
                                <span>System Administrator</span>
                            </div>
                        </td>
                        <td>admin@swp39...</td>
                        <td><span class="badge bg-danger">Admin</span></td>
                        <td>01/01/2026</td>
                        <td><span class="badge badge-active">Hoạt động</span></td>
                        <td>
                            <a href="#" class="btn btn-sm btn-outline-primary"><i class="bi bi-eye"></i></a>
                            <a href="#" class="btn btn-sm btn-outline-warning"><i class="bi bi-pencil"></i></a>
                        </td>
                    </tr>
                    <tr>
                        <td>2</td>
                        <td>
                            <div class="d-flex align-items-center">
                                <img src="https://ui-avatars.com/api/?name=Nguyen+Van+Instructor&background=3498db&color=fff" 
                                     class="rounded-circle me-2" width="36" height="36">
                                <span>Nguyen Van Instructor</span>
                            </div>
                        </td>
                        <td>instructor@swp...</td>
                        <td><span class="badge bg-primary">Instructor</span></td>
                        <td>15/01/2026</td>
                        <td><span class="badge badge-active">Hoạt động</span></td>
                        <td>
                            <a href="#" class="btn btn-sm btn-outline-primary"><i class="bi bi-eye"></i></a>
                            <a href="#" class="btn btn-sm btn-outline-warning"><i class="bi bi-pencil"></i></a>
                            <button class="btn btn-sm btn-outline-danger"><i class="bi bi-lock"></i></button>
                        </td>
                    </tr>
                    <tr>
                        <td>3</td>
                        <td>
                            <div class="d-flex align-items-center">
                                <img src="https://ui-avatars.com/api/?name=Tran+Thi+Mentor&background=27ae60&color=fff" 
                                     class="rounded-circle me-2" width="36" height="36">
                                <span>Tran Thi Mentor</span>
                            </div>
                        </td>
                        <td>Student1@swp...</td>
                        <td><span class="badge bg-success">Student</span></td>
                        <td>20/01/2026</td>
                        <td><span class="badge badge-active">Hoạt động</span></td>
                        <td>
                            <a href="#" class="btn btn-sm btn-outline-primary"><i class="bi bi-eye"></i></a>
                            <a href="#" class="btn btn-sm btn-outline-warning"><i class="bi bi-pencil"></i></a>
                            <button class="btn btn-sm btn-outline-danger"><i class="bi bi-lock"></i></button>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
        <div class="card-footer">
            <div class="d-flex justify-content-between align-items-center">
                <span class="text-muted">Hiển thị 1-3 của 3 người dùng</span>
                <nav>
                    <ul class="pagination pagination-sm mb-0">
                        <li class="page-item disabled"><a class="page-link" href="#">Trước</a></li>
                        <li class="page-item active"><a class="page-link" href="#">1</a></li>
                        <li class="page-item disabled"><a class="page-link" href="#">Sau</a></li>
                    </ul>
                </nav>
            </div>
        </div>
    </div>
</div>
