@page
@model SWP_QA_TOOL.Pages.Admin.Users.IndexModel
@{
    ViewData["Title"] = "Quản lý người dùng";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h3><i class="bi bi-people"></i> Quản lý người dùng</h3>
                    <p class="text-muted mb-0">Danh sách tất cả người dùng trong hệ thống</p>
                </div>
                <a href="/Admin/Users/Create" class="btn btn-admin-primary">
                    <i class="bi bi-person-plus"></i> Thêm người dùng
                </a>
            </div>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Filter -->
    <div class="card mb-4">
        <div class="card-body">
            <form method="get" class="row g-3">
                <div class="col-md-3">
                    <input type="text" asp-for="SearchTerm" class="form-control" placeholder="Tìm kiếm theo tên, email, mssv...">
                </div>
                <div class="col-md-2">
                    <select asp-for="RoleName" class="form-select">
                        <option value="ALL">-- Tất cả Role --</option>
                        <option value="Admin">Admin</option>
                        <option value="Instructor">Instructor</option>
                        <option value="Student">Student</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <select asp-for="Status" class="form-select">
                        <option value="ALL">-- Trạng thái --</option>
                        <option value="Active">Hoạt động</option>
                        <option value="Inactive">Bị khóa</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-outline-primary w-100">
                        <i class="bi bi-search"></i> Tìm kiếm
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Users Table -->
    <div class="card">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Họ tên</th>
                        <th>Email</th>
                        <th>MSSV</th>
                        <th>Role</th>
                        <th>Ngày tạo</th>
                        <th>Trạng thái</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Users != null && Model.Users.Any())
                    {
                        int index = 1;
                        foreach (var user in Model.Users)
                        {
                            <tr>
                                <td>@index</td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <img src="@(string.IsNullOrEmpty(user.AvatarUrl) ? $"https://ui-avatars.com/api/?name={Uri.EscapeDataString(user.FullName)}&background=random&color=fff" : user.AvatarUrl)" 
                                             class="rounded-circle me-2" width="36" height="36">
                                        <span>@user.FullName</span>
                                    </div>
                                </td>
                                <td>@user.Email</td>
                                <td>@(user.StudentId ?? "-")</td>
                                <td>
                                    @if(user.RoleName == "Admin")
                                    {
                                        <span class="badge bg-danger">@user.RoleName</span>
                                    }
                                    else if(user.RoleName == "Instructor")
                                    {
                                        <span class="badge bg-primary">@user.RoleName</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">@user.RoleName</span>
                                    }
                                </td>
                                <td>@(user.CreatedAt?.ToString("dd/MM/yyyy") ?? "-")</td>
                                <td>
                                    @if(user.IsActive == true)
                                    {
                                        <span class="badge badge-active text-bg-success">Hoạt động</span>
                                    }
                                    else
                                    {
                                        <span class="badge text-bg-secondary">Bị khóa</span>
                                    }
                                </td>
                                <td>
                                    <a href="/Admin/Users/Details/@user.UserId" class="btn btn-sm btn-outline-primary" title="Chi tiết"><i class="bi bi-eye"></i></a>
                                    <a href="#" class="btn btn-sm btn-outline-warning" title="Sửa"><i class="bi bi-pencil"></i></a>
                                    <button class="btn btn-sm btn-outline-danger" title="Khóa"><i class="bi bi-lock"></i></button>
                                </td>
                            </tr>
                            index++;
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="text-center">Không tìm thấy người dùng nào.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="card-footer">
            <div class="d-flex justify-content-between align-items-center">
                <span class="text-muted">Hiển thị @Model.Users.Count() người dùng</span>
            </div>
        </div>
    </div>
</div>
