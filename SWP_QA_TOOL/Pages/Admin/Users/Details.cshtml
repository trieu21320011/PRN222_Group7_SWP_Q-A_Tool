@page "{id:int}"
@model SWP_QA_TOOL.Pages.Admin.Users.DetailsModel
@{
    ViewData["Title"] = "Chi tiết người dùng";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/Admin">Dashboard</a></li>
                    <li class="breadcrumb-item"><a href="/Admin/Users">Người dùng</a></li>
                    <li class="breadcrumb-item active">Chi tiết</li>
                </ol>
            </nav>
            <h3><i class="bi bi-person-lines-fill"></i> Hồ sơ người dùng</h3>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger" role="alert">
            <i class="bi bi-exclamation-triangle"></i> @Model.ErrorMessage
        </div>
    }
    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="alert alert-success" role="alert">
            <i class="bi bi-check-circle"></i> @Model.SuccessMessage
        </div>
    }

    <div class="row">
        <!-- Thông tin User -->
        <div class="col-md-5 mb-4">
            <div class="card h-100">
                <div class="card-header bg-primary text-white">
                    <i class="bi bi-person-badge"></i> Thông tin cơ bản
                </div>
                <div class="card-body">
                    <div class="text-center mb-4">
                        <img src="@(string.IsNullOrEmpty(Model.UserDetails.AvatarUrl) ? $"https://ui-avatars.com/api/?name={Uri.EscapeDataString(Model.UserDetails.FullName)}&background=random&color=fff" : Model.UserDetails.AvatarUrl)" 
                             class="rounded-circle img-thumbnail" width="120" height="120">
                        <h4 class="mt-2 text-primary">@Model.UserDetails.FullName</h4>
                        <span class="badge @(Model.UserDetails.RoleName == "Admin" ? "bg-danger" : Model.UserDetails.RoleName == "Instructor" ? "bg-primary" : "bg-success") px-3 py-2">
                            @Model.UserDetails.RoleName
                        </span>
                    </div>

                    <ul class="list-group list-group-flush">
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <span class="text-muted">Email</span>
                            <strong>@Model.UserDetails.Email</strong>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <span class="text-muted">MSSV</span>
                            <strong>@(Model.UserDetails.StudentId ?? "N/A")</strong>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <span class="text-muted">Ngày tạo</span>
                            <strong>@(Model.UserDetails.CreatedAt?.ToString("dd/MM/yyyy HH:mm") ?? "N/A")</strong>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <span class="text-muted">Trạng thái</span>
                            @if(Model.UserDetails.IsActive == true)
                            {
                                <span class="badge badge-active text-bg-success"><i class="bi bi-check-circle"></i> Hoạt động</span>
                            }
                            else
                            {
                                <span class="badge text-bg-secondary">Bị khóa</span>
                            }
                        </li>
                    </ul>
                </div>
            </div>
        </div>

        <!-- Groups / Cores -->
        <div class="col-md-7 mb-4">
            <div class="card mb-4">
                <div class="card-header bg-success text-white">
                    <i class="bi bi-diagram-3"></i> Nhóm / Lớp học (Cores & Teams)
                </div>
                <div class="card-body">
                    <form method="post" asp-page-handler="AssignTeam" class="row g-3 mb-4">
                        <div class="col-md-8">
                            <input type="text" asp-for="TeamCode" class="form-control" placeholder="Nhập mã Team (ví dụ: SE1701_G1)" required>
                        </div>
                        <div class="col-md-4">
                            <button type="submit" class="btn btn-primary w-100">
                                <i class="bi bi-plus-circle"></i> Gán vào nhóm
                            </button>
                        </div>
                    </form>

                    <h6 class="border-bottom pb-2 mb-3">Các nhóm đã tham gia</h6>
                    @if (Model.UserTeams.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover table-bordered align-middle text-center">
                                <thead class="table-light">
                                    <tr>
                                        <th>Mã Nhóm</th>
                                        <th>Tên Nhóm</th>
                                        <th>Lớp / Core</th>
                                        <th>Kỳ học</th>
                                        <th>Thao tác</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach(var team in Model.UserTeams)
                                    {
                                        <tr>
                                            <td><strong>@team.TeamCode</strong></td>
                                            <td>@team.TeamName</td>
                                            <td><span class="badge bg-info text-dark">@(team.CoreName ?? "Không xác định")</span></td>
                                            <td>@(team.SemesterCode ?? "-")</td>
                                            <td>
                                                <a href="/Admin/Questions?TeamFilter=@team.TeamName" class="btn btn-sm btn-outline-info">
                                                    <i class="bi bi-clock-history"></i> Xem lịch sử
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-secondary text-center" role="alert">
                            Học sinh này chưa tham gia bất kỳ nhóm hoặc Core nào.
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
