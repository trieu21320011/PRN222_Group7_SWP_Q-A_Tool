@page "{id:int}"
@model SWP_QA_TOOL.Pages.Admin.Users.EditModel
@{
    ViewData["Title"] = "Chỉnh sửa người dùng";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-page="/Admin/Index">Dashboard</a></li>
                    <li class="breadcrumb-item"><a asp-page="Index">Người dùng</a></li>
                    <li class="breadcrumb-item active">Chỉnh sửa</li>
                </ol>
            </nav>
            <h3><i class="bi bi-pencil-square"></i> Chỉnh sửa người dùng</h3>
        </div>
    </div>

    <div class="row">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-header bg-warning text-dark">
                    <i class="bi bi-person-gear"></i> Thông tin người dùng
                </div>
                <div class="card-body">
                    <form method="post">
                        @Html.AntiForgeryToken()

                        <input type="hidden" asp-for="Input.UserId" />

                        <div class="text-danger mb-3">
                            @Html.ValidationSummary()
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Họ và tên <span class="text-danger">*</span></label>
                                <input asp-for="Input.FullName" class="form-control" placeholder="Nhập họ và tên">
                                <span asp-validation-for="Input.FullName" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Tên hiển thị</label>
                                <input asp-for="Input.DisplayName" class="form-control" placeholder="Nhập tên hiển thị">
                                <span asp-validation-for="Input.DisplayName" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Email <span class="text-danger">*</span></label>
                                <input asp-for="Input.Email" type="email" class="form-control" placeholder="example@fpt.edu.vn">
                                <span asp-validation-for="Input.Email" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Mã sinh viên</label>
                                <input asp-for="Input.StudentId" class="form-control" placeholder="SE123456">
                                <span asp-validation-for="Input.StudentId" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Vai trò <span class="text-danger">*</span></label>
                                <select asp-for="Input.RoleId" class="form-select" asp-items="Model.RoleList">
                                    <option value="">-- Chọn vai trò --</option>
                                </select>
                                <span asp-validation-for="Input.RoleId" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Trạng thái</label>
                                <div class="d-flex gap-4 mt-2">
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" name="Input.IsActive" id="isActiveTrue" value="true" @(Model.Input.IsActive ? "checked" : "") />
                                        <label class="form-check-label text-success" for="isActiveTrue">
                                            <i class="bi bi-check-circle"></i> Kích hoạt
                                        </label>
                                    </div>
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" name="Input.IsActive" id="isActiveFalse" value="false" @(!Model.Input.IsActive ? "checked" : "") />
                                        <label class="form-check-label text-danger" for="isActiveFalse">
                                            <i class="bi bi-x-circle"></i> Khóa
                                        </label>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <hr />

                        <div class="d-flex justify-content-between">
                            <a asp-page="Index" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left"></i> Quay lại
                            </a>
                            <button type="submit" class="btn btn-warning">
                                <i class="bi bi-check-lg"></i> Lưu thay đổi
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card">
                <div class="card-header">
                    <i class="bi bi-info-circle"></i> Lưu ý
                </div>
                <div class="card-body">
                    <ul class="list-unstyled mb-0">
                        <li class="mb-2">
                            <i class="bi bi-exclamation-circle text-warning"></i> 
                            Thay đổi vai trò sẽ ảnh hưởng đến quyền truy cập
                        </li>
                        <li class="mb-2">
                            <i class="bi bi-lock text-danger"></i> 
                            Khóa tài khoản sẽ ngăn người dùng đăng nhập
                        </li>
                        <li class="mb-2">
                            <i class="bi bi-envelope text-primary"></i> 
                            Email không được trùng với người dùng khác
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
