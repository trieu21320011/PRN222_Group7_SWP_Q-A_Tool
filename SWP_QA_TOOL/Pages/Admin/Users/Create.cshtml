@page
@model SWP_QA_TOOL.Pages.Admin.Users.CreateModel
@{
    ViewData["Title"] = "Thêm người dùng";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/Admin">Dashboard</a></li>
                    <li class="breadcrumb-item"><a href="/Admin/Users">Người dùng</a></li>
                    <li class="breadcrumb-item active">Thêm mới</li>
                </ol>
            </nav>
            <h3><i class="bi bi-person-plus"></i> Thêm người dùng mới</h3>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill"></i> @Model.ErrorMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header">
                    <i class="bi bi-info-circle"></i> Thông tin người dùng
                </div>
                <div class="card-body">
                    <form method="post">
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label">Họ và tên <span class="text-danger">*</span></label>
                                <input type="text" asp-for="Input.FullName" class="form-control" placeholder="Nhập họ và tên" required>
                                <span asp-validation-for="Input.FullName" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Tên hiển thị</label>
                                <input type="text" asp-for="Input.DisplayName" class="form-control" placeholder="Nhập tên hiển thị">
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label">Email <span class="text-danger">*</span></label>
                                <input type="email" asp-for="Input.Email" class="form-control" placeholder="example@fpt.edu.vn" required>
                                <span asp-validation-for="Input.Email" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Mã sinh viên</label>
                                <input type="text" asp-for="Input.StudentId" class="form-control" placeholder="SE123456">
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label">Mật khẩu <span class="text-danger">*</span></label>
                                <input type="password" asp-for="Input.PasswordHash" class="form-control" placeholder="Nhập mật khẩu" required>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Xác nhận mật khẩu <span class="text-danger">*</span></label>
                                <input type="password" asp-for="ConfirmPassword" class="form-control" placeholder="Nhập lại mật khẩu" required>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label">Vai trò <span class="text-danger">*</span></label>
                                <select asp-for="Input.RoleId" asp-items="Model.RoleOptions" class="form-select" required>
                                    <option value="">-- Chọn vai trò --</option>
                                </select>
                                <span asp-validation-for="Input.RoleId" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Trạng thái</label>
                                <div class="form-check form-switch mt-2">
                                    <input class="form-check-input" type="checkbox" id="IsActiveCheck" name="Input.IsActive" value="true" checked>
                                    <input type="hidden" name="Input.IsActive" value="false" />
                                    <label class="form-check-label" for="IsActiveCheck">Kích hoạt</label>
                                </div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Ghi chú (Bio)</label>
                            <textarea asp-for="Input.Bio" class="form-control" rows="3" placeholder="Ghi chú thêm (nếu có)"></textarea>
                        </div>

                        <hr />

                        <div class="d-flex justify-content-end gap-2">
                            <a href="/Admin/Users" class="btn btn-outline-secondary">
                                <i class="bi bi-x-circle"></i> Hủy
                            </a>
                            <button type="submit" class="btn btn-admin-primary">
                                <i class="bi bi-check-circle"></i> Lưu
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card">
                <div class="card-header">
                    <i class="bi bi-lightbulb"></i> Hướng dẫn
                </div>
                <div class="card-body">
                    <ul class="list-unstyled mb-0">
                        <li class="mb-2">
                            <i class="bi bi-check-circle text-success"></i> 
                            Họ tên phải đầy đủ theo CMND/CCCD
                        </li>
                        <li class="mb-2">
                            <i class="bi bi-check-circle text-success"></i> 
                            Email phải là email FPT (@@fpt.edu.vn)
                        </li>
                        <li class="mb-2">
                            <i class="bi bi-check-circle text-success"></i> 
                            Mật khẩu tối thiểu 6 ký tự
                        </li>
                        <li class="mb-2">
                            <i class="bi bi-info-circle text-primary"></i> 
                            Vai trò: <br/>
                            - Mặc định 1: Admin<br/>
                            - 2: Instructor<br/>
                            - 3: Student
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>
