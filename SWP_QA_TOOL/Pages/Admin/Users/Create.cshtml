@page
@model SWP_QA_TOOL.Pages.Admin.Users.CreateModel
@{
    ViewData["Title"] = "Thêm người dùng";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-page="/Admin/Index">Dashboard</a></li>
                    <li class="breadcrumb-item"><a asp-page="Index">Người dùng</a></li>
                    <li class="breadcrumb-item active">Thêm mới</li>
                </ol>
            </nav>
            <div class="d-flex justify-content-between align-items-center">
                <h3><i class="bi bi-person-plus"></i> Thêm người dùng mới</h3>
                <a asp-page="Import" class="btn btn-success">
                    <i class="bi bi-file-earmark-excel"></i> Import từ Excel
                </a>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <i class="bi bi-info-circle"></i> Thông tin người dùng
                </div>
                <div class="card-body">
                    <form method="post">
                        @Html.AntiForgeryToken()

                        <div class="text-danger mb-3">
                            @Html.ValidationSummary()
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Họ và tên <span class="text-danger">*</span></label>
                                <input asp-for="Input.FullName" class="form-control" placeholder="Nhập họ và tên">
                                <span asp-validation-for="Input.FullName" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Tên hiển thị</label>
                                <input asp-for="Input.DisplayName" class="form-control" placeholder="Nhập tên hiển thị">
                                <span asp-validation-for="Input.DisplayName" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Email <span class="text-danger">*</span></label>
                                <input asp-for="Input.Email" type="email" class="form-control" placeholder="example@fpt.edu.vn">
                                <span asp-validation-for="Input.Email" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Mã sinh viên</label>
                                <input asp-for="Input.StudentId" class="form-control" placeholder="SE123456">
                                <span asp-validation-for="Input.StudentId" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Mật khẩu <span class="text-danger">*</span></label>
                                <input asp-for="Input.Password" type="password" class="form-control" placeholder="Nhập mật khẩu">
                                <span asp-validation-for="Input.Password" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Xác nhận mật khẩu <span class="text-danger">*</span></label>
                                <input asp-for="Input.ConfirmPassword" type="password" class="form-control" placeholder="Nhập lại mật khẩu">
                                <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Vai trò <span class="text-danger">*</span></label>
                                <select asp-for="Input.RoleId" class="form-select" asp-items="Model.RoleList">
                                    <option value="">-- Chọn vai trò --</option>
                                </select>
                                <span asp-validation-for="Input.RoleId" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Trạng thái</label>
                                <div class="d-flex gap-4 mt-2">
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" name="Input.IsActive" id="isActiveTrue" value="true" checked />
                                        <label class="form-check-label text-success" for="isActiveTrue">
                                            <i class="bi bi-check-circle"></i> Kích hoạt
                                        </label>
                                    </div>
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" name="Input.IsActive" id="isActiveFalse" value="false" />
                                        <label class="form-check-label text-danger" for="isActiveFalse">
                                            <i class="bi bi-x-circle"></i> Khóa
                                        </label>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <hr />

                        <div class="d-flex justify-content-between">
                            <a asp-page="Index" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left"></i> Quay lại
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-check-circle"></i> Tạo người dùng
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card">
                <div class="card-header">
                    <i class="bi bi-lightbulb"></i> Hướng dẫn
                </div>
                <div class="card-body">
                    <ul class="list-unstyled mb-0">
                        <li class="mb-2">
                            <i class="bi bi-check-circle text-success"></i> 
                            Họ tên phải đầy đủ theo CMND/CCCD
                        </li>
                        <li class="mb-2">
                            <i class="bi bi-check-circle text-success"></i> 
                            Email phải là email FPT (@@fpt.edu.vn)
                        </li>
                        <li class="mb-2">
                            <i class="bi bi-check-circle text-success"></i> 
                            Mật khẩu tối thiểu 6 ký tự
                        </li>
                        <li class="mb-2">
                            <i class="bi bi-info-circle text-primary"></i> 
                            Vai trò xác định quyền truy cập của người dùng
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
