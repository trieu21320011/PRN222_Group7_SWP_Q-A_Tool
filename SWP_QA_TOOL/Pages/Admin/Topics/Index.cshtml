@page
@model SWP_QA_TOOL.Pages.Admin.Topics.IndexModel

@{
    ViewData["Title"] = "Quản lý Đề tài";
}

<h2>Quản lý Đề tài</h2>

<p>
    <a asp-page="Create" class="btn btn-primary">Tạo Đề tài mới</a>
</p>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>ID</th>
            <th>Mã đề tài</th>
            <th>Tên đề tài</th>
            <th>Học kỳ</th>
            <th>Danh mục</th>
            <th>Độ khó</th>
            <th>Số nhóm tối đa</th>
            <th>Số nhóm hiện tại</th>
            <th>Trạng thái</th>
            <th style="width:220px;">Thao tác</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.Topics)
        {
            <tr>
                <td>@item.TopicId</td>
                <td>@item.TopicCode</td>
                <td>@item.TopicName</td>
                <td>@item.SemesterCode</td>
                <td>@item.Category</td>
                <td>@item.Difficulty</td>
                <td>@item.MaxTeams</td>
                <td>@item.CurrentTeams</td>
                <td>@(item.IsActive == true ? "Hoạt động" : "Không hoạt động")</td>
                <td>
                    <a asp-page="Details" asp-route-id="@item.TopicId" class="btn btn-sm btn-info">Chi tiết</a>
                    <a asp-page="Edit" asp-route-id="@item.TopicId" class="btn btn-sm btn-warning">Sửa</a>
                    <a asp-page="Delete" asp-route-id="@item.TopicId" class="btn btn-sm btn-danger">Xóa</a>
                </td>
            </tr>
        }
    </tbody>
</table>
