@page "{id:int}"
@model SWP_QA_TOOL.Pages.Admin.Topics.DetailsModel

@{
    ViewData["Title"] = "Chi tiết Đề tài";
}

<h2>Chi tiết Đề tài</h2>

<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header">
                <h5>Thông tin Đề tài</h5>
            </div>
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-3">ID</dt>
                    <dd class="col-sm-9">@Model.Topic.TopicId</dd>

                    <dt class="col-sm-3">Mã đề tài</dt>
                    <dd class="col-sm-9">@Model.Topic.TopicCode</dd>

                    <dt class="col-sm-3">Tên đề tài</dt>
                    <dd class="col-sm-9">@Model.Topic.TopicName</dd>

                    <dt class="col-sm-3">Mô tả</dt>
                    <dd class="col-sm-9">@Model.Topic.Description</dd>

                    <dt class="col-sm-3">Học kỳ</dt>
                    <dd class="col-sm-9">@Model.Topic.SemesterCode</dd>

                    <dt class="col-sm-3">Danh mục</dt>
                    <dd class="col-sm-9">@Model.Topic.Category</dd>

                    <dt class="col-sm-3">Độ khó</dt>
                    <dd class="col-sm-9">@Model.Topic.Difficulty</dd>

                    <dt class="col-sm-3">Trạng thái</dt>
                    <dd class="col-sm-9">@(Model.Topic.IsActive == true ? "Hoạt động" : "Không hoạt động")</dd>

                    <dt class="col-sm-3">Ngày tạo</dt>
                    <dd class="col-sm-9">@Model.Topic.CreatedAt?.ToString("dd/MM/yyyy HH:mm")</dd>
                </dl>
            </div>
        </div>
    </div>
    
    <div class="col-md-4">
        <div class="card">
            <div class="card-header bg-info text-white">
                <h5>Thống kê Nhóm đăng ký</h5>
            </div>
            <div class="card-body text-center">
                <div class="display-4">@Model.Topic.CurrentTeams / @Model.Topic.MaxTeams</div>
                <p class="text-muted">Số nhóm đã đăng ký / Tối đa</p>
                @if (Model.Topic.MaxTeams > 0)
                {
                    var percentage = (Model.Topic.CurrentTeams ?? 0) * 100 / Model.Topic.MaxTeams;
                    <div class="progress mt-3" style="height: 25px;">
                        <div class="progress-bar @(percentage >= 90 ? "bg-danger" : percentage >= 50 ? "bg-warning" : "bg-success")"
                             role="progressbar" style="width: @percentage%;" aria-valuenow="@percentage" aria-valuemin="0" aria-valuemax="100">
                            @percentage%
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<div class="mt-3">
    <a asp-page="Edit" asp-route-id="@Model.Topic.TopicId" class="btn btn-warning">Sửa</a>
    <a asp-page="Index" class="btn btn-secondary">Quay lại danh sách</a>
</div>
