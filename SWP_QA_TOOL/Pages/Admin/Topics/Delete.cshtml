@page "{id:int}"
@model SWP_QA_TOOL.Pages.Admin.Topics.DeleteModel

@{
    ViewData["Title"] = "Xóa Đề tài";
}

<h2>Xóa Đề tài</h2>

<div class="alert alert-warning">
    Bạn có chắc chắn muốn xóa đề tài này?
</div>

<div class="card">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">ID</dt>
            <dd class="col-sm-9">@Model.Topic.TopicId</dd>

            <dt class="col-sm-3">Mã đề tài</dt>
            <dd class="col-sm-9">@Model.Topic.TopicCode</dd>

            <dt class="col-sm-3">Tên đề tài</dt>
            <dd class="col-sm-9">@Model.Topic.TopicName</dd>

            <dt class="col-sm-3">Mô tả</dt>
            <dd class="col-sm-9">@Model.Topic.Description</dd>

            <dt class="col-sm-3">Học kỳ</dt>
            <dd class="col-sm-9">@Model.Topic.SemesterCode</dd>

            <dt class="col-sm-3">Danh mục</dt>
            <dd class="col-sm-9">@Model.Topic.Category</dd>

            <dt class="col-sm-3">Độ khó</dt>
            <dd class="col-sm-9">@Model.Topic.Difficulty</dd>

            <dt class="col-sm-3">Số nhóm đăng ký</dt>
            <dd class="col-sm-9">@Model.Topic.CurrentTeams / @Model.Topic.MaxTeams</dd>

            <dt class="col-sm-3">Trạng thái</dt>
            <dd class="col-sm-9">@(Model.Topic.IsActive == true ? "Hoạt động" : "Không hoạt động")</dd>
        </dl>
    </div>
</div>

<form method="post" class="mt-3">
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" value="@Model.Topic.TopicId" />
    <button type="submit" class="btn btn-danger">Xóa</button>
    <a asp-page="Index" class="btn btn-secondary">Hủy</a>
</form>
