@page
@model Web.Pages.Topics.CreateModel

<h2>Create Topic</h2>

<form method="post">

    <div class="form-group">
        <label>Topic Code</label>
        <input asp-for="Topic.TopicCode" class="form-control" />
    </div>

    <div class="form-group">
        <label>Topic Name</label>
        <input asp-for="Topic.TopicName" class="form-control" />
    </div>

    <div class="form-group">
        <label>Description</label>
<textarea asp-for="Topic.Description" class="form-control"></textarea>
    </div>

    <div class="form-group">
        <label>Semester Id</label>
        <input asp-for="Topic.SemesterId" class="form-control" />
    </div>

    <div class="form-group">
        <label>Category</label>
        <input asp-for="Topic.Category" class="form-control" />
    </div>

    <div class="form-group">
        <label>Difficulty</label>
        <input asp-for="Topic.Difficulty" class="form-control" />
    </div>

    <div class="form-group">
        <label>Max Teams</label>
        <input asp-for="Topic.MaxTeams" class="form-control" />
    </div>

    <button type="submit" class="btn btn-success mt-3">Create</button>

</form>