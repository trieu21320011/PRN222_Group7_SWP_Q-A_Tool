@page "{id:int}"
@model SWP_QA_TOOL.Pages.Admin.Cores.EditModel

@{
    ViewData["Title"] = "Chỉnh sửa Lớp học";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-header bg-warning text-dark">
                    <h4 class="mb-0"><i class="bi bi-pencil-square"></i> Chỉnh sửa Lớp học</h4>
                </div>
                <div class="card-body">
                    <form method="post">
                        @Html.AntiForgeryToken()

                        <input type="hidden" asp-for="Input.CoreId" />

                        <div class="text-danger mb-3">
                            @Html.ValidationSummary()
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Mã Lớp <span class="text-danger">*</span></label>
                                <input asp-for="Input.CoreCode" class="form-control" placeholder="VD: SE1601" />
                                <span asp-validation-for="Input.CoreCode" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Tên Lớp <span class="text-danger">*</span></label>
                                <input asp-for="Input.CoreName" class="form-control" placeholder="VD: Software Engineering" />
                                <span asp-validation-for="Input.CoreName" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Giảng viên phụ trách</label>
                                <select asp-for="Input.InstructorId" class="form-select" asp-items="Model.InstructorList">
                                    <option value="">-- Chọn giảng viên --</option>
                                </select>
                                <span asp-validation-for="Input.InstructorId" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Số nhóm tối đa</label>
                                <input asp-for="Input.MaxTeams" type="number" class="form-control" min="1" placeholder="VD: 10" />
                                <span asp-validation-for="Input.MaxTeams" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Lịch học</label>
                                <input asp-for="Input.Schedule" class="form-control" placeholder="VD: Thứ 2, 7:30-9:30" />
                                <span asp-validation-for="Input.Schedule" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Phòng học</label>
                                <input asp-for="Input.Room" class="form-control" placeholder="VD: DE-C201" />
                                <span asp-validation-for="Input.Room" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Trạng thái</label>
                            <div class="d-flex gap-4">
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="Input.IsActive" id="isActiveTrue" value="true" @(Model.Input.IsActive == true ? "checked" : "") />
                                    <label class="form-check-label text-success" for="isActiveTrue">
                                        <i class="bi bi-check-circle"></i> Hoạt động
                                    </label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="Input.IsActive" id="isActiveFalse" value="false" @(Model.Input.IsActive == false ? "checked" : "") />
                                    <label class="form-check-label text-danger" for="isActiveFalse">
                                        <i class="bi bi-x-circle"></i> Không hoạt động
                                    </label>
                                </div>
                            </div>
                        </div>

                        <hr />

                        <div class="d-flex justify-content-between">
                            <a asp-page="Index" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left"></i> Quay lại
                            </a>
                            <button type="submit" class="btn btn-warning">
                                <i class="bi bi-check-lg"></i> Lưu thay đổi
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
