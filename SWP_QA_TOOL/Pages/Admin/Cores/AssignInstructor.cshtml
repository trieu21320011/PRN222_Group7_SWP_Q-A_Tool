@page
@model SWP_QA_TOOL.Pages.Admin.Cores.AssignInstructorModel
@{
    ViewData["Title"] = "Phân công giảng viên";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2><i class="bi bi-person-badge"></i> Phân công giảng viên vào lớp học</h2>
            <p class="text-muted">Chọn giảng viên để phụ trách từng lớp học</p>
        </div>
        <a asp-page="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Quay lại
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-circle"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Filter by Semester -->
    <div class="card mb-4">
        <div class="card-body">
            <form method="get" class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label class="form-label fw-bold">Lọc theo học kỳ</label>
                    <select name="SemesterId" class="form-select" onchange="this.form.submit()">
                        <option value="">-- Tất cả học kỳ --</option>
                        @foreach (var semester in Model.SemesterList)
                        {
                            <option value="@semester.Value" selected="@(Model.SemesterId.ToString() == semester.Value.ToString())">
                                @semester.Text
                            </option>
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    <span class="badge bg-info fs-6">
                        <i class="bi bi-collection"></i> @Model.Cores.Count() lớp học
                    </span>
                    <span class="badge bg-success fs-6 ms-2">
                        <i class="bi bi-people"></i> @Model.Instructors.Count() giảng viên
                    </span>
                </div>
            </form>
        </div>
    </div>

    <div class="row">
        <!-- Cores List -->
        <div class="col-lg-8">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="bi bi-collection"></i> Danh sách lớp học</h5>
                </div>
                <div class="card-body p-0">
                    @if (Model.Cores.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Mã lớp</th>
                                        <th>Tên lớp</th>
                                        <th>Học kỳ</th>
                                        <th>Giảng viên hiện tại</th>
                                        <th>Phân công</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var core in Model.Cores)
                                    {
                                        <tr>
                                            <td><strong>@core.CoreCode</strong></td>
                                            <td>@core.CoreName</td>
                                            <td><span class="badge bg-info">@(core.SemesterCode ?? "N/A")</span></td>
                                            <td>
                                                @if (!string.IsNullOrEmpty(core.InstructorName))
                                                {
                                                    <span class="badge bg-success">
                                                        <i class="bi bi-person-check"></i> @core.InstructorName
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-warning text-dark">
                                                        <i class="bi bi-person-x"></i> Chưa phân công
                                                    </span>
                                                }
                                            </td>
                                            <td>
                                                <form method="post" asp-page-handler="Assign" class="d-flex gap-2">
                                                    <input type="hidden" name="CoreId" value="@core.CoreId" />
                                                    <input type="hidden" name="SemesterId" value="@Model.SemesterId" />
                                                    <select name="InstructorId" class="form-select form-select-sm" style="width: 180px;" required>
                                                        <option value="">-- Chọn --</option>
                                                        @foreach (var instructor in Model.Instructors)
                                                        {
                                                            <option value="@instructor.UserId">@instructor.FullName</option>
                                                        }
                                                    </select>
                                                    <button type="submit" class="btn btn-sm btn-primary">
                                                        <i class="bi bi-check-lg"></i>
                                                    </button>
                                                </form>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="bi bi-inbox display-1 text-muted"></i>
                            <p class="text-muted mt-3">Không có lớp học nào.</p>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Instructors Panel -->
        <div class="col-lg-4">
            <div class="card">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0"><i class="bi bi-people"></i> Danh sách giảng viên</h5>
                </div>
                <div class="card-body p-0">
                    @if (Model.Instructors.Any())
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var instructor in Model.Instructors)
                            {
                                var assignedCores = Model.Cores.Count(c => c.InstructorName == instructor.FullName);
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    <div>
                                        <i class="bi bi-person-circle text-primary"></i>
                                        <strong class="ms-2">@instructor.FullName</strong>
                                        <br />
                                        <small class="text-muted">@instructor.Email</small>
                                    </div>
                                    <span class="badge rounded-pill @(assignedCores > 0 ? "bg-primary" : "bg-secondary")">
                                        @assignedCores lớp
                                    </span>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <div class="text-center py-4">
                            <i class="bi bi-person-x display-4 text-muted"></i>
                            <p class="text-muted mt-2">Không có giảng viên.</p>
                        </div>
                    }
                </div>
            </div>

            <!-- Stats Card -->
            <div class="card mt-4">
                <div class="card-header bg-warning text-dark">
                    <h5 class="mb-0"><i class="bi bi-bar-chart"></i> Thống kê nhanh</h5>
                </div>
                <div class="card-body">
                    <div class="row text-center">
                        <div class="col-6">
                            <div class="h3 text-success">@Model.Cores.Count(c => !string.IsNullOrEmpty(c.InstructorName))</div>
                            <small class="text-muted">Đã phân công</small>
                        </div>
                        <div class="col-6">
                            <div class="h3 text-warning">@Model.Cores.Count(c => string.IsNullOrEmpty(c.InstructorName))</div>
                            <small class="text-muted">Chưa phân công</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
