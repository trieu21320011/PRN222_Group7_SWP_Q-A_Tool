@page "{id:int}"
@model SWP_QA_TOOL.Pages.Admin.Cores.DetailsModel

@{
    ViewData["Title"] = "Chi tiết Lớp học";
}

<h2>Chi tiết Lớp học</h2>

<div class="row">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <h5>Thông tin Lớp học</h5>
            </div>
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-4">ID</dt>
                    <dd class="col-sm-8">@Model.Core.CoreId</dd>

                    <dt class="col-sm-4">Mã Lớp</dt>
                    <dd class="col-sm-8">@Model.Core.CoreCode</dd>

                    <dt class="col-sm-4">Tên Lớp</dt>
                    <dd class="col-sm-8">@Model.Core.CoreName</dd>

                    <dt class="col-sm-4">Học kỳ</dt>
                    <dd class="col-sm-8">@Model.Core.SemesterCode</dd>

                    <dt class="col-sm-4">Giảng viên phụ trách</dt>
                    <dd class="col-sm-8">@Model.Core.InstructorName</dd>

                    <dt class="col-sm-4">Lịch học</dt>
                    <dd class="col-sm-8">@Model.Core.Schedule</dd>

                    <dt class="col-sm-4">Phòng học</dt>
                    <dd class="col-sm-8">@Model.Core.Room</dd>

                    <dt class="col-sm-4">Số nhóm</dt>
                    <dd class="col-sm-8">@Model.Core.CurrentTeams / @Model.Core.MaxTeams</dd>

                    <dt class="col-sm-4">Trạng thái</dt>
                    <dd class="col-sm-8">@(Model.Core.IsActive == true ? "Hoạt động" : "Không hoạt động")</dd>

                    <dt class="col-sm-4">Ngày tạo</dt>
                    <dd class="col-sm-8">@Model.Core.CreatedAt?.ToString("dd/MM/yyyy HH:mm")</dd>
                </dl>
            </div>
        </div>
    </div>
    
    <div class="col-md-6">
        <div class="card">
            <div class="card-header bg-info text-white">
                <h5>Thống kê Nhóm</h5>
            </div>
            <div class="card-body text-center">
                <div class="display-4">@Model.Core.CurrentTeams / @Model.Core.MaxTeams</div>
                <p class="text-muted">Số nhóm trong Lớp / Tối đa</p>
                @if (Model.Core.MaxTeams > 0)
                {
                    var percentage = (Model.Core.CurrentTeams ?? 0) * 100 / Model.Core.MaxTeams;
                    <div class="progress mt-3" style="height: 25px;">
                        <div class="progress-bar @(percentage >= 90 ? "bg-danger" : percentage >= 50 ? "bg-warning" : "bg-success")"
                             role="progressbar" style="width: @percentage%;" aria-valuenow="@percentage" aria-valuemin="0" aria-valuemax="100">
                            @percentage%
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- Teams in Core -->
<div class="card mt-4">
    <div class="card-header">
        <h5>Danh sách Nhóm trong Lớp</h5>
    </div>
    <div class="card-body">
        @if (Model.Teams.Any())
        {
            <table class="table table-bordered table-striped">
                <thead>
                    <tr>
                        <th>Mã nhóm</th>
                        <th>Tên nhóm</th>
                        <th>Dự án</th>
                        <th>Đề tài</th>
                        <th>Trưởng nhóm</th>
                        <th>Mentor</th>
                        <th>Trạng thái</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var team in Model.Teams)
                    {
                        <tr>
                            <td>@team.TeamCode</td>
                            <td>@team.TeamName</td>
                            <td>@team.ProjectName</td>
                            <td>@team.TopicName</td>
                            <td>@team.LeaderName</td>
                            <td>@team.MentorName</td>
                            <td>@(team.IsActive == true ? "Hoạt động" : "Không hoạt động")</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="alert alert-info">Chưa có nhóm nào trong Core này.</div>
        }
    </div>
</div>

<div class="mt-3">
    <a asp-page="Edit" asp-route-id="@Model.Core.CoreId" class="btn btn-warning">Sửa</a>
    <a asp-page="Index" class="btn btn-secondary">Quay lại danh sách</a>
</div>
