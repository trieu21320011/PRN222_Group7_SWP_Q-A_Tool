@page
@model SWP_QA_TOOL.Pages.Admin.Reports.IndexModel
@{
    ViewData["Title"] = "Báo cáo tổng hợp";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2><i class="bi bi-file-earmark-bar-graph"></i> Báo cáo tổng hợp</h2>
            <p class="text-muted">Tổng quan thống kê hệ thống</p>
        </div>
        <div>
            <button class="btn btn-outline-primary" onclick="window.print()">
                <i class="bi bi-printer"></i> In báo cáo
            </button>
        </div>
    </div>

    <!-- Filter -->
    <div class="card mb-4">
        <div class="card-body">
            <form method="get" class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label class="form-label fw-bold">Lọc theo học kỳ</label>
                    <select name="SemesterId" class="form-select" onchange="this.form.submit()">
                        <option value="">-- Tất cả học kỳ --</option>
                        @foreach (var semester in Model.SemesterList)
                        {
                            <option value="@semester.Value" selected="@(Model.SemesterId.ToString() == semester.Value.ToString())">
                                @semester.Text
                            </option>
                        }
                    </select>
                </div>
            </form>
        </div>
    </div>

    <!-- Summary Cards -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card bg-primary text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h6 class="card-title">Tổng học kỳ</h6>
                            <h2>@Model.TotalSemesters</h2>
                        </div>
                        <i class="bi bi-calendar3 display-4 opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-success text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h6 class="card-title">Tổng lớp học</h6>
                            <h2>@Model.TotalCores</h2>
                        </div>
                        <i class="bi bi-collection display-4 opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-info text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h6 class="card-title">Tổng nhóm</h6>
                            <h2>@Model.TotalTeams</h2>
                        </div>
                        <i class="bi bi-people display-4 opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-warning text-dark">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h6 class="card-title">Tổng câu hỏi</h6>
                            <h2>@Model.TotalQuestions</h2>
                        </div>
                        <i class="bi bi-question-circle display-4 opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row mb-4">
        <!-- Q&A Statistics -->
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header bg-light">
                    <h5 class="mb-0"><i class="bi bi-chat-dots"></i> Thống kê Q&A</h5>
                </div>
                <div class="card-body">
                    <div class="row text-center">
                        <div class="col-6">
                            <div class="h1 text-success">@Model.ResolvedQuestions</div>
                            <p class="text-muted">Đã giải quyết</p>
                            @if (Model.TotalQuestions > 0)
                            {
                                <div class="progress" style="height: 10px;">
                                    <div class="progress-bar bg-success" style="width: @((Model.ResolvedQuestions * 100 / Model.TotalQuestions))%"></div>
                                </div>
                                <small class="text-muted">@((Model.ResolvedQuestions * 100 / Model.TotalQuestions))%</small>
                            }
                        </div>
                        <div class="col-6">
                            <div class="h1 text-warning">@Model.PendingQuestions</div>
                            <p class="text-muted">Chờ trả lời</p>
                            @if (Model.TotalQuestions > 0)
                            {
                                <div class="progress" style="height: 10px;">
                                    <div class="progress-bar bg-warning" style="width: @((Model.PendingQuestions * 100 / Model.TotalQuestions))%"></div>
                                </div>
                                <small class="text-muted">@((Model.PendingQuestions * 100 / Model.TotalQuestions))%</small>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- User Statistics -->
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header bg-light">
                    <h5 class="mb-0"><i class="bi bi-people"></i> Thống kê người dùng</h5>
                </div>
                <div class="card-body">
                    <div class="row text-center">
                        <div class="col-4">
                            <div class="h1 text-primary">@Model.TotalUsers</div>
                            <p class="text-muted">Tổng cộng</p>
                        </div>
                        <div class="col-4">
                            <div class="h1 text-info">@Model.TotalInstructors</div>
                            <p class="text-muted">Giảng viên</p>
                        </div>
                        <div class="col-4">
                            <div class="h1 text-success">@Model.TotalStudents</div>
                            <p class="text-muted">Sinh viên</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Core Details Table -->
    <div class="card">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0"><i class="bi bi-table"></i> Chi tiết lớp học</h5>
        </div>
        <div class="card-body p-0">
            @if (Model.CoreReports.Any())
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th>#</th>
                                <th>Mã lớp</th>
                                <th>Tên lớp</th>
                                <th>Học kỳ</th>
                                <th>Giảng viên</th>
                                <th>Số nhóm</th>
                                <th>Trạng thái</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{ var index = 1; }
                            @foreach (var core in Model.CoreReports)
                            {
                                <tr>
                                    <td>@index</td>
                                    <td><strong>@core.CoreCode</strong></td>
                                    <td>@core.CoreName</td>
                                    <td><span class="badge bg-info">@core.SemesterCode</span></td>
                                    <td>
                                        @if (core.InstructorName != "Chưa phân công")
                                        {
                                            <span class="text-success"><i class="bi bi-person-check"></i> @core.InstructorName</span>
                                        }
                                        else
                                        {
                                            <span class="text-warning"><i class="bi bi-person-x"></i> @core.InstructorName</span>
                                        }
                                    </td>
                                    <td>
                                        <span class="badge bg-primary">@core.TeamCount / @core.MaxTeams</span>
                                    </td>
                                    <td>
                                        @if (core.IsActive)
                                        {
                                            <span class="badge bg-success">Hoạt động</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Ngừng</span>
                                        }
                                    </td>
                                </tr>
                                index++;
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="bi bi-inbox display-1 text-muted"></i>
                    <p class="text-muted mt-3">Không có dữ liệu.</p>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <style>
        @@media print {
            .btn, form, .navbar, .sidebar {
                display: none !important;
            }
            .card {
                break-inside: avoid;
            }
        }
    </style>
}
