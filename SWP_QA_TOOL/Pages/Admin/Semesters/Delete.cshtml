@page "{id:int}"
@model PresentationLayer.Areas.Admin.Pages.Semesters.DeleteModel

@{
    ViewData["Title"] = "Delete Semester";
}

<h2>Delete Semester</h2>

<div class="alert alert-warning">
    Are you sure you want to delete this semester?
</div>

<div class="card">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">SemesterId</dt>
            <dd class="col-sm-9">@Model.Semester?.SemesterId</dd>

            <dt class="col-sm-3">SemesterCode</dt>
            <dd class="col-sm-9">@Model.Semester?.SemesterCode</dd>

            <dt class="col-sm-3">SemesterName</dt>
            <dd class="col-sm-9">@Model.Semester?.SemesterName</dd>

            <dt class="col-sm-3">StartDate</dt>
            <dd class="col-sm-9">@Model.Semester?.StartDate.ToString("dd/MM/yyyy")</dd>

            <dt class="col-sm-3">EndDate</dt>
            <dd class="col-sm-9">@Model.Semester?.EndDate.ToString("dd/MM/yyyy")</dd>

            <dt class="col-sm-3">IsActive</dt>
            <dd class="col-sm-9">@((Model.Semester?.IsActive == true) ? "Yes" : "No")</dd>

            <dt class="col-sm-3">IsCurrent</dt>
            <dd class="col-sm-9">@((Model.Semester?.IsCurrent == true) ? "Yes" : "No")</dd>
        </dl>
    </div>
</div>

<form method="post" class="mt-3">
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" value="@Model.Semester?.SemesterId" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-page="Index" class="btn btn-secondary">Cancel</a>
</form>
